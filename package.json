{
  "name": "pdf-knowledge-graph",
  "version": "1.0.0",
  "description": "Sistema de procesamiento de documentos PDF que construye un grafo de conocimiento en Neo4j utilizando Google Genkit",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:pbt": "jest --testNamePattern=\"Property\"",
    "lint": "tsc --noEmit",
    "db:clear": "ts-node scripts/clear-database.ts",
    "db:init": "ts-node scripts/init-schema.ts"
  },
  "keywords": [
    "pdf",
    "knowledge-graph",
    "neo4j",
    "genkit",
    "ai",
    "nlp",
    "vector-search"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.7.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@genkit-ai/core": "^1.34.0",
    "@genkit-ai/google-genai": "^1.34.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "fast-check": "^4.8.0",
    "genkitx-groq": "^0.30.0",
    "genkitx-neo4j": "^0.5.17",
    "multer": "^2.1.1",
    "neo4j-driver": "^6.0.1",
    "pdf-parse": "^1.1.1",
    "undici": "^8.3.0"
  }
}
