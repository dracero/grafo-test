---
/**
 * Comparison page — normative document vs program
 * Converted from public/compare.html to Astro component
 */
import UserSessionIsland from '../components/UserSessionIsland.astro';
import { t } from '../lib/i18n';

const currentLang = Astro.locals.lang || 'es';
---
<!DOCTYPE html>
<html lang={currentLang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Comparación de documento normativo con programa de materia">
  <title>{t('nav.compare', currentLang)} — Knowledge Graph</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
  <style is:global>
    /* ── Comparison Page Layout ── */
    html, body {
      overflow-y: auto !important;
      height: auto !important;
    }
    .page-container {
      min-height: 100vh;
      padding-top: var(--top-bar-height);
    }
    .compare-content {
      max-width: 1200px;
      margin: 0 auto;
      padding: 32px 24px;
    }
    .page-hero { text-align: center; margin-bottom: 40px; }
    .page-hero h1 {
      font-size: 2rem; font-weight: 800;
      background: linear-gradient(135deg, var(--accent-violet), var(--accent-cyan));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text; margin-bottom: 8px;
    }
    .page-hero p { color: var(--text-secondary); font-size: 1rem; max-width: 600px; margin: 0 auto; line-height: 1.6; }
    .upload-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 32px; }
    .upload-card {
      background: var(--bg-secondary); border: 2px dashed var(--border-light);
      border-radius: var(--radius-lg); padding: 32px; text-align: center;
      transition: all var(--transition-normal); cursor: pointer; position: relative; overflow: hidden;
    }
    .upload-card:hover { border-color: var(--accent-violet); background: var(--bg-elevated); }
    .upload-card.has-file { border-color: var(--accent-emerald); border-style: solid; }
    .upload-card input[type="file"] { display: block; margin: 15px auto 0; cursor: pointer; font-size: 0.9rem; color: var(--text-secondary); }
    .upload-card input[type="file"]::file-selector-button {
      background: var(--bg-tertiary); border: 1px solid var(--border-light); padding: 6px 12px;
      border-radius: var(--radius-sm); color: var(--text-primary); font-weight: 600; cursor: pointer;
      margin-right: 12px; transition: all var(--transition-fast);
    }
    .upload-card input[type="file"]::file-selector-button:hover { background: var(--bg-elevated); border-color: var(--accent-violet); }
    .upload-icon { font-size: 2.5rem; margin-bottom: 12px; display: block; }
    .upload-card h3 { font-size: 1rem; font-weight: 700; color: var(--text-primary); margin-bottom: 6px; }
    .upload-card p { font-size: 0.82rem; color: var(--text-muted); line-height: 1.5; }
    .upload-filename { margin-top: 12px; font-size: 0.85rem; font-weight: 600; color: var(--accent-emerald); display: none; }
    .upload-card.has-file .upload-filename { display: block; }
    .upload-card.has-file .upload-hint { display: none; }
    .compare-actions { text-align: center; margin-bottom: 40px; }
    .btn-compare {
      padding: 14px 40px; font-size: 1rem; border-radius: var(--radius-md);
      background: linear-gradient(135deg, var(--accent-violet), #7C3AED); color: white;
      border: none; font-weight: 700; font-family: var(--font-sans); cursor: pointer;
      transition: all var(--transition-fast); box-shadow: var(--shadow-glow-violet);
    }
    .btn-compare:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 0 36px rgba(139, 92, 246, 0.35); }
    .btn-compare:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }
    .options-container { text-align: center; margin-bottom: 24px; }
    .checkbox-label { display: inline-flex; align-items: center; gap: 8px; font-size: 0.9rem; color: var(--text-secondary); cursor: pointer; }
    .checkbox-label input { width: 16px; height: 16px; accent-color: var(--accent-violet); }
    .progress-bar { display: none; margin-bottom: 32px; }
    .progress-bar.active { display: block; }
    .progress-track { height: 6px; background: var(--bg-tertiary); border-radius: var(--radius-full); overflow: hidden; }
    .progress-fill { height: 100%; background: linear-gradient(90deg, var(--accent-violet), var(--accent-cyan)); border-radius: var(--radius-full); width: 0%; animation: progressPulse 2s ease-in-out infinite; }
    .progress-fill.indeterminate { width: 40%; animation: progressSlide 1.5s ease-in-out infinite; }
    @keyframes progressSlide { 0% { transform: translateX(-100%); } 100% { transform: translateX(350%); } }
    .progress-status { font-size: 0.82rem; color: var(--text-secondary); text-align: center; margin-top: 10px; }
    .results-section { display: none; }
    .results-section.visible { display: block; }
    .summary-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 32px; }
    .summary-card { background: var(--bg-secondary); border-radius: var(--radius-md); padding: 20px; text-align: center; border: 1px solid var(--border-subtle); }
    .summary-card .value { font-size: 2rem; font-weight: 800; font-variant-numeric: tabular-nums; }
    .summary-card .label { font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin-top: 4px; }
    .value-covered { color: var(--accent-emerald); }
    .value-partial { color: var(--accent-amber); }
    .value-missing { color: var(--accent-rose); }
    .value-total { color: var(--accent-cyan); }
    .coverage-bar-container { margin-bottom: 32px; background: var(--bg-secondary); border-radius: var(--radius-md); padding: 20px 24px; border: 1px solid var(--border-subtle); }
    .coverage-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
    .coverage-header h3 { font-size: 0.9rem; font-weight: 700; }
    .coverage-percent { font-size: 1.5rem; font-weight: 800; }
    .coverage-track { height: 12px; background: var(--bg-primary); border-radius: var(--radius-full); overflow: hidden; display: flex; }
    .coverage-segment { height: 100%; transition: width var(--transition-slow); }
    .coverage-segment.covered { background: var(--accent-emerald); }
    .coverage-segment.partial { background: var(--accent-amber); }
    .coverage-segment.missing { background: var(--accent-rose); opacity: 0.4; }
    .coverage-legend { display: flex; gap: 20px; margin-top: 12px; justify-content: center; }
    .coverage-legend-item { display: flex; align-items: center; gap: 6px; font-size: 0.78rem; color: var(--text-secondary); }
    .coverage-legend-dot { width: 10px; height: 10px; border-radius: 3px; }
    .results-table-container { background: var(--bg-secondary); border-radius: var(--radius-md); border: 1px solid var(--border-subtle); overflow: hidden; }
    .results-table-header { padding: 16px 20px; border-bottom: 1px solid var(--border-subtle); display: flex; align-items: center; justify-content: space-between; }
    .results-table-header h3 { font-size: 0.95rem; font-weight: 700; }
    .filter-tabs { display: flex; gap: 4px; }
    .filter-tab { padding: 5px 12px; font-size: 0.72rem; font-weight: 600; border: 1px solid var(--border-light); border-radius: var(--radius-full); background: transparent; color: var(--text-secondary); cursor: pointer; font-family: var(--font-sans); transition: all var(--transition-fast); }
    .filter-tab.active, .filter-tab:hover { background: var(--accent-violet); color: white; border-color: var(--accent-violet); }
    .result-row { padding: 16px 20px; border-bottom: 1px solid var(--border-subtle); transition: background var(--transition-fast); }
    .result-row:last-child { border-bottom: none; }
    .result-row:hover { background: var(--bg-elevated); }
    .result-row-header { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
    .status-badge { display: inline-flex; align-items: center; gap: 4px; padding: 3px 10px; border-radius: var(--radius-full); font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; }
    .status-covered { background: rgba(16,185,129,0.15); color: var(--accent-emerald); }
    .status-partial { background: rgba(245,158,11,0.15); color: var(--accent-amber); }
    .status-missing { background: rgba(244,63,94,0.15); color: var(--accent-rose); }
    .result-id { font-size: 0.72rem; font-weight: 700; color: var(--text-muted); font-variant-numeric: tabular-nums; }
    .result-category { font-size: 0.68rem; font-weight: 600; padding: 2px 8px; border-radius: var(--radius-full); background: var(--bg-tertiary); color: var(--accent-cyan); }
    .result-requirement { font-size: 0.88rem; font-weight: 600; color: var(--text-primary); margin-left: auto; flex: 1; }
    .result-details { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 8px; }
    .result-detail-box { padding: 10px 14px; background: var(--bg-primary); border-radius: var(--radius-sm); border-left: 3px solid var(--border-light); }
    .result-detail-box.evidence { border-left-color: var(--accent-cyan); }
    .result-detail-box.suggestion { border-left-color: var(--accent-amber); }
    .detail-label { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); margin-bottom: 4px; }
    .detail-text { font-size: 0.8rem; color: var(--text-secondary); line-height: 1.5; }
    .nav-link { font-size: 0.82rem; font-weight: 600; color: var(--text-secondary); text-decoration: none; padding: 6px 14px; border-radius: var(--radius-sm); transition: all var(--transition-fast); border: 1px solid var(--border-light); }
    .nav-link:hover { color: var(--text-primary); background: var(--bg-tertiary); }
    @media (max-width: 768px) {
      .upload-grid { grid-template-columns: 1fr; }
      .summary-grid { grid-template-columns: repeat(2, 1fr); }
      .result-details { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <!-- Top Bar -->
  <header class="top-bar">
    <div class="top-bar-left">
      <div class="logo">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
          <circle cx="14" cy="14" r="12" stroke="url(#lg2)" stroke-width="2.5" fill="none"/>
          <circle cx="8" cy="11" r="2.5" fill="#8B5CF6"/><circle cx="18" cy="9" r="2.5" fill="#06B6D4"/><circle cx="15" cy="19" r="2.5" fill="#F59E0B"/>
          <line x1="8" y1="11" x2="18" y2="9" stroke="#8B5CF680" stroke-width="1.5"/>
          <line x1="18" y1="9" x2="15" y2="19" stroke="#06B6D480" stroke-width="1.5"/>
          <defs><linearGradient id="lg2" x1="0" y1="0" x2="28" y2="28"><stop stop-color="#8B5CF6"/><stop offset="1" stop-color="#06B6D4"/></linearGradient></defs>
        </svg>
        <span class="logo-text">Knowledge Graph</span>
      </div>
    </div>
    <div class="top-bar-right" style="display:flex; align-items:center; gap:12px;">
      <a href="/rubric" class="nav-link">📝 {t('nav.rubric', currentLang)}</a>
      <a href="/" class="nav-link">← {t('nav.reload', currentLang) === 'Recargar' ? 'Volver al Grafo' : 'Back to Graph'}</a>
      
      <UserSessionIsland server:defer>
        <div slot="fallback" style="color: #9ca3af; font-size: 0.75rem; padding: 6px 12px; background: rgba(255,255,255,0.05); border-radius:8px; border:1px solid rgba(255,255,255,0.08); min-width: 120px; text-align: center;">{t('loading', currentLang)}</div>
      </UserSessionIsland>
    </div>
  </header>

  <div class="page-container">
    <div class="compare-content">
      <div class="page-hero">
        <h1>Comparación Normativa</h1>
        <p>Subí el documento normativo y el programa de materia para analizar la cobertura de requisitos y detectar puntos faltantes.</p>
      </div>

      <div class="upload-grid">
        <div class="upload-card" id="card-normative">
          <input type="file" accept=".pdf" id="file-normative">
          <span class="upload-icon">📋</span>
          <h3>Documento Normativo</h3>
          <p class="upload-hint">Resolución, ordenanza o reglamento que establece los requisitos</p>
          <p class="upload-filename" id="name-normative"></p>
        </div>
        <div class="upload-card" id="card-program">
          <input type="file" accept=".pdf" id="file-program">
          <span class="upload-icon">📚</span>
          <h3>Programa de Materia</h3>
          <p class="upload-hint">Programa o plan de estudios a evaluar contra la normativa</p>
          <p class="upload-filename" id="name-program"></p>
        </div>
      </div>

      <div class="options-container" style="display: flex; flex-direction: column; align-items: center; gap: 16px; margin-bottom: 24px;">
        <div style="display: flex; align-items: center; gap: 12px; justify-content: center; background: var(--bg-secondary); padding: 10px 20px; border-radius: var(--radius-md); border: 1px solid var(--border-subtle); box-shadow: var(--shadow-sm);">
          <label for="model-provider" style="font-size: 0.88rem; color: var(--text-secondary); font-weight: 600;">Proveedor de IA:</label>
          <select id="model-provider" style="background: var(--bg-primary); border: 1px solid var(--border-light); padding: 8px 14px; border-radius: var(--radius-sm); color: var(--text-primary); font-family: var(--font-sans); font-size: 0.88rem; cursor: pointer; outline: none; transition: border-color var(--transition-fast);">
            <option value="gemini">Google Gemini (Gemini 3.5 Flash)</option>
            <option value="groq">Groq (Llama 3.3 70B)</option>
          </select>
        </div>
        
        <label class="checkbox-label">
          <input type="checkbox" id="clear-previous" checked>
          Borrar comparaciones anteriores del grafo
        </label>
      </div>

      <div class="compare-actions">
        <button id="btn-compare" class="btn-compare" disabled>Comparar Documentos</button>
      </div>

      <div class="progress-bar" id="progress-bar">
        <div class="progress-track"><div class="progress-fill indeterminate"></div></div>
        <p class="progress-status" id="progress-status">Extrayendo ontología del documento normativo...</p>
      </div>

      <div class="results-section" id="results-section">
        <div class="doc-names-container" id="doc-names-container" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; flex-wrap: wrap; gap: 16px; background: var(--bg-secondary); padding: 16px 20px; border-radius: var(--radius-md); border: 1px solid var(--border-subtle);">
          <div style="display: flex; gap: 16px; flex-wrap: wrap;">
            <div class="doc-badge" style="background: rgba(139, 92, 246, 0.08); border: 1px solid rgba(139, 92, 246, 0.2); padding: 8px 14px; border-radius: var(--radius-md); display: flex; align-items: center; gap: 8px;">
              <span style="font-size: 1.1rem;">📋</span>
              <div>
                <div style="font-size: 0.65rem; text-transform: uppercase; font-weight: 700; color: var(--text-muted); letter-spacing: 0.04em;">Documento Normativo</div>
                <div id="display-normative-name" style="font-size: 0.85rem; font-weight: 600; color: var(--text-primary);">—</div>
              </div>
            </div>
            <div class="doc-badge" style="background: rgba(6, 182, 212, 0.08); border: 1px solid rgba(6, 182, 212, 0.2); padding: 8px 14px; border-radius: var(--radius-md); display: flex; align-items: center; gap: 8px;">
              <span style="font-size: 1.1rem;">📚</span>
              <div>
                <div style="font-size: 0.65rem; text-transform: uppercase; font-weight: 700; color: var(--text-muted); letter-spacing: 0.04em;">Programa de Materia</div>
                <div id="display-program-name" style="font-size: 0.85rem; font-weight: 600; color: var(--text-primary);">—</div>
              </div>
            </div>
          </div>
          <div style="display: flex; gap: 12px; align-items: center;">
            <button id="btn-fix" class="btn-compare" style="background: linear-gradient(135deg, var(--accent-emerald), #059669); box-shadow: 0 0 18px rgba(16, 185, 129, 0.25); display: none; padding: 10px 24px; font-size: 0.88rem; font-weight: 700; height: auto;">
              🔧 Arreglar Programa
            </button>
            <button id="btn-download-non-compliance" class="btn-compare" style="background: linear-gradient(135deg, var(--accent-rose), #e11d48); box-shadow: 0 0 18px rgba(244, 63, 94, 0.25); display: none; padding: 10px 24px; font-size: 0.88rem; font-weight: 700; height: auto;">
              📥 Descargar No Conformidades
            </button>
          </div>
        </div>

        <div class="summary-grid" id="summary-grid"></div>
        <div class="coverage-bar-container" id="coverage-container"></div>
        <div class="results-table-container" id="results-table"></div>
      </div>
    </div>
  </div>

  <div id="toast-container" class="toast-container"></div>

  <!-- Fix Modal -->
  <div id="fix-modal" class="modal-overlay" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(15, 23, 42, 0.8); backdrop-filter: blur(8px); z-index: 1000; align-items: center; justify-content: center;">
    <div class="modal-content" style="background: var(--bg-secondary); border: 1px solid var(--border-subtle); border-radius: var(--radius-lg); max-width: 600px; width: 90%; padding: 32px; box-shadow: var(--shadow-lg);">
      <h2 style="font-size: 1.4rem; font-weight: 800; background: linear-gradient(135deg, var(--accent-emerald), var(--accent-cyan)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 16px; margin-top: 0;">Corrección de Programa con Multi-Agente</h2>
      <p id="fix-modal-description" style="color: var(--text-secondary); font-size: 0.88rem; margin-bottom: 24px; line-height: 1.5;">El sistema multi-agente está procesando el programa de la materia utilizando el proveedor de IA seleccionado para corregir los puntos faltantes o parciales de acuerdo a la normativa.</p>
      
      <div id="fix-steps" style="display: flex; flex-direction: column; gap: 14px; margin-bottom: 28px;">
        <div class="fix-step" id="step-start" style="display: flex; align-items: center; gap: 12px; color: var(--text-muted); font-size: 0.9rem;">
          <span class="step-status" style="width: 20px; text-align: center;">⏳</span>
          <span>Iniciando sistema de agentes ADK...</span>
        </div>
        <div class="fix-step" id="step-normative" style="display: flex; align-items: center; gap: 12px; color: var(--text-muted); font-size: 0.9rem;">
          <span class="step-status" style="width: 20px; text-align: center;">⏳</span>
          <span>Agente Normativo: Leyendo requisitos en Neo4j...</span>
        </div>
        <div class="fix-step" id="step-program" style="display: flex; align-items: center; gap: 12px; color: var(--text-muted); font-size: 0.9rem;">
          <span class="step-status" style="width: 20px; text-align: center;">⏳</span>
          <span>Agente del Programa: Leyendo estructura en Neo4j...</span>
        </div>
        <div class="fix-step" id="step-compliance" style="display: flex; align-items: center; gap: 12px; color: var(--text-muted); font-size: 0.9rem;">
          <span class="step-status" style="width: 20px; text-align: center;">⏳</span>
          <span>Agente de Cumplimiento: Analizando brechas (gaps)...</span>
        </div>
        <div class="fix-step" id="step-validator" style="display: flex; align-items: center; gap: 12px; color: var(--text-muted); font-size: 0.9rem;">
          <span class="step-status" style="width: 20px; text-align: center;">⏳</span>
          <span>Validador Semántico: Descartando falsas brechas...</span>
        </div>
        <div class="fix-step" id="step-fixer" style="display: flex; align-items: center; gap: 12px; color: var(--text-muted); font-size: 0.9rem;">
          <span class="step-status" style="width: 20px; text-align: center;">⏳</span>
          <span class="step-text">Agente Corrector: Modificando programa...</span>
        </div>
        <div class="fix-step" id="step-pdf" style="display: flex; align-items: center; gap: 12px; color: var(--text-muted); font-size: 0.9rem;">
          <span class="step-status" style="width: 20px; text-align: center;">⏳</span>
          <span>Generador: Creando PDF con formato normativo...</span>
        </div>
      </div>

      <div style="display: flex; justify-content: flex-end; gap: 12px;">
        <button id="btn-close-modal" class="filter-tab" style="padding: 8px 18px; font-size: 0.85rem; height: auto; cursor: pointer;">Cerrar</button>
        <a id="btn-download-pdf" class="btn-compare" style="background: linear-gradient(135deg, var(--accent-cyan), #0891b2); box-shadow: 0 0 18px rgba(6, 182, 212, 0.25); text-decoration: none; display: none; padding: 10px 20px; font-size: 0.85rem; font-weight: 700; align-items: center; gap: 8px; height: auto;">
          📥 Descargar PDF Corregido
        </a>
      </div>
    </div>
  </div>

  <script is:inline src="/compare.js"></script>
</body>
</html>
