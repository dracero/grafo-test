---
/**
 * Rubric Generator page — Multi-agent rubric generation.
 * Upload 2 PDFs (normative + evaluation schema) → multi-agent pipeline → preview → download PDF → clear.
 */
import UserSessionIsland from '../components/UserSessionIsland.astro';
import { t } from '../lib/i18n';

const currentLang = Astro.locals.lang || 'es';

// Local UI labels for self-contained translation block
const rubricLabels = {
  document: currentLang === 'en' ? 'Document' : currentLang === 'pt' ? 'Documento' : 'Documento',
  criteria: currentLang === 'en' ? 'Criteria' : currentLang === 'pt' ? 'Critérios' : 'Criterios',
  dimensions: currentLang === 'en' ? 'Dimensions' : currentLang === 'gl' ? 'Dimensións' : 'Dimensiones',
  totalWeight: currentLang === 'en' ? 'Total Weight' : currentLang === 'pt' ? 'Peso Total' : 'Peso Total',
  method: currentLang === 'en' ? 'Method' : currentLang === 'pt' ? 'Método' : 'Método',
  multiAgent: currentLang === 'en' ? 'Multi-Agent' : currentLang === 'gl' ? 'Multi-Axente' : 'Multi-Agente',
  nonEvaluableTitle: currentLang === 'en' ? '⚠️ Normative Aspects Not Included in the Rubric' : currentLang === 'gl' ? '⚠️ Aspectos Normativos Non Incluídos na Rúbrica' : currentLang === 'pt' ? '⚠️ Aspectos Normativos Não Incluídos na Rubrica' : '⚠️ Aspectos Normativos No Incluidos en la Rúbrica',
  processing: currentLang === 'en' ? 'Processing documents...' : currentLang === 'gl' ? 'Procesando documentos...' : currentLang === 'pt' ? 'Processando documentos...' : 'Procesando documentos...'
};

// Client-side mapping
const rubricTranslations = {
  executing_pipeline: t('rubric.js.executing_pipeline', currentLang),
  extracting_text: t('rubric.js.extracting_text', currentLang),
  extracting_ontology: t('rubric.js.extracting_ontology', currentLang),
  agent1_running: t('rubric.js.agent1_running', currentLang),
  agent2_running: t('rubric.js.agent2_running', currentLang),
  agent3_running: t('rubric.js.agent3_running', currentLang),
  rendering_preview: t('rubric.js.rendering_preview', currentLang),
  generate_success: t('rubric.js.generate_success', currentLang),
  clear_db_confirm: t('rubric.js.clear_db_confirm', currentLang),
  clearing: t('rubric.js.clearing', currentLang),
  clear_success: t('rubric.js.clear_success', currentLang),
  dimension: t('rubric.js.dimension', currentLang),
  component: t('rubric.js.component', currentLang),
  components: t('rubric.js.components', currentLang),
  table_evaluated_component: t('rubric.js.table.evaluated_component', currentLang),
  table_institutional_criterion: t('rubric.js.table.institutional_criterion', currentLang),
  table_level_excellent: t('rubric.js.table.level_excellent', currentLang),
  table_level_acceptable: t('rubric.js.table.level_acceptable', currentLang),
  table_level_insufficient: t('rubric.js.table.level_insufficient', currentLang),
  table_label_optimo: t('rubric.js.table.label_optimo', currentLang),
  table_label_acceptable: t('rubric.js.table.label_acceptable', currentLang),
  table_label_deficiente: t('rubric.js.table.label_deficiente', currentLang),
  reason: t('rubric.js.reason', currentLang),
  recommendation: t('rubric.js.recommendation', currentLang),
  pts_max: t('rubric.js.pts_max', currentLang),
  btn_generate: t('rubric.btn_generate', currentLang),
  btn_clear: t('rubric.btn_clear', currentLang)
};
---
<!DOCTYPE html>
<html lang={currentLang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Generador de rúbricas multi-agente para evaluación de guías docentes">
  <title>{t('rubric.title', currentLang)} — Knowledge Graph</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
  <style is:global>
    /* ── Rubric Page Layout ── */
    html, body {
      overflow-y: auto !important;
      height: auto !important;
    }
    .page-container {
      min-height: 100vh;
      padding-top: var(--top-bar-height);
    }
    .rubric-content {
      max-width: 1400px;
      margin: 0 auto;
      padding: 32px 24px 60px;
    }
  </style>
  <script is:inline define:vars={{ rubricTranslations }}>
    window.AppTranslations = rubricTranslations;
  </script>
</head>
<body>
  <!-- Top Bar -->
  <header id="top-bar" class="top-bar">
    <div class="top-bar-left">
      <div class="logo">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
          <circle cx="14" cy="14" r="12" stroke="url(#logo-grad-r)" stroke-width="2.5" fill="none"/>
          <circle cx="8" cy="11" r="2.5" fill="#8B5CF6"/>
          <circle cx="18" cy="9" r="2.5" fill="#06B6D4"/>
          <circle cx="15" cy="19" r="2.5" fill="#F59E0B"/>
          <line x1="8" y1="11" x2="18" y2="9" stroke="#8B5CF680" stroke-width="1.5"/>
          <line x1="18" y1="9" x2="15" y2="19" stroke="#06B6D480" stroke-width="1.5"/>
          <line x1="8" y1="11" x2="15" y2="19" stroke="#F59E0B80" stroke-width="1.5"/>
          <defs><linearGradient id="logo-grad-r" x1="0" y1="0" x2="28" y2="28"><stop stop-color="#8B5CF6"/><stop offset="1" stop-color="#06B6D4"/></linearGradient></defs>
        </svg>
        <span class="logo-text">Knowledge Graph</span>
      </div>
    </div>
    <div class="top-bar-right" style="display:flex; align-items:center; gap:12px;">
      <a href="/compare" class="nav-link">📊 {t('nav.compare', currentLang)}</a>
      <a href="/" class="nav-link">← {t('rubric.back_to_graph', currentLang)}</a>
      
      <UserSessionIsland server:defer>
        <div slot="fallback" style="color: #9ca3af; font-size: 0.75rem; padding: 6px 12px; background: rgba(255,255,255,0.05); border-radius:8px; border:1px solid rgba(255,255,255,0.08); min-width: 120px; text-align: center;">{t('loading', currentLang)}</div>
      </UserSessionIsland>
    </div>
  </header>

  <div class="page-container">
    <div class="rubric-content">
      <!-- Hero -->
      <div class="page-hero">
        <span class="multi-agent-badge">{t('rubric.system_badge', currentLang)}</span>
        <h1>📝 {t('rubric.title', currentLang)}</h1>
        <p>{t('rubric.subtitle', currentLang)}</p>
      </div>

      <!-- Steps indicator (5 steps) -->
      <div class="rubric-steps" id="rubric-steps">
        <div class="rubric-step" id="step-upload">
          <span class="step-num">1</span>
          <span>{t('rubric.step1', currentLang)}</span>
        </div>
        <div class="rubric-step" id="step-extract">
          <span class="step-num">2</span>
          <span>{t('rubric.step2', currentLang)}</span>
        </div>
        <div class="rubric-step" id="step-ontology-agent">
          <span class="step-num">3</span>
          <span>{t('rubric.step3', currentLang)}</span>
        </div>
        <div class="rubric-step" id="step-adjuster-agent">
          <span class="step-num">4</span>
          <span>{t('rubric.step4', currentLang)}</span>
        </div>
        <div class="rubric-step" id="step-synthesizer-agent">
          <span class="step-num">5</span>
          <span>{t('rubric.step5', currentLang)}</span>
        </div>
      </div>

      <!-- Upload Cards (2) -->
      <div class="upload-grid" id="upload-section">
        <!-- Normative PDF -->
        <div class="upload-card-rubric" data-type="normative" id="card-normative-rubric">
          <input type="file" accept=".pdf" id="file-normative-rubric">
          <span class="upload-icon">📋</span>
          <h3>{t('rubric.normative_title', currentLang)}</h3>
          <p class="upload-hint">{t('rubric.normative_desc', currentLang)}</p>
          <p class="upload-filename-rubric" id="name-normative-rubric"></p>
        </div>

        <!-- Evaluation Schema PDF -->
        <div class="upload-card-rubric" data-type="schema" id="card-schema-rubric">
          <input type="file" accept=".pdf" id="file-schema-rubric">
          <span class="upload-icon">📐</span>
          <h3>{t('rubric.schema_title', currentLang)}</h3>
          <p class="upload-hint">{t('rubric.schema_desc', currentLang)}</p>
          <p class="upload-filename-rubric" id="name-schema-rubric"></p>
        </div>
      </div>

      <!-- IA Provider Options -->
      <div class="options-container" style="display: flex; justify-content: center; margin-bottom: 24px;">
        <div style="display: flex; align-items: center; gap: 12px; justify-content: center; background: var(--bg-secondary); padding: 10px 20px; border-radius: var(--radius-md); border: 1px solid var(--border-subtle); box-shadow: var(--shadow-sm);">
          <label for="model-provider" style="font-size: 0.88rem; color: var(--text-secondary); font-weight: 600;">{t('rubric.ai_provider', currentLang)}</label>
          <select id="model-provider" style="background: var(--bg-primary); border: 1px solid var(--border-light); padding: 8px 14px; border-radius: var(--radius-sm); color: var(--text-primary); font-family: var(--font-sans); font-size: 0.88rem; cursor: pointer; outline: none; transition: border-color var(--transition-fast);">
            <option value="gemini">Google Gemini (Gemini 3.5 Flash)</option>
            <option value="groq">Groq (Llama 3.3 70B)</option>
          </select>
        </div>
      </div>

      <!-- Actions -->
      <div class="rubric-actions" id="rubric-actions">
        <button id="btn-generate-rubric" class="btn-generate" disabled>
          {t('rubric.btn_generate', currentLang)}
        </button>
        <a id="btn-download-rubric" class="btn-download-rubric" download="rubrica.pdf">
          {t('rubric.btn_download', currentLang)}
        </a>
        <button id="btn-clear-rubric" class="btn-clear-rubric">
          {t('rubric.btn_clear', currentLang)}
        </button>
      </div>

      <!-- Progress -->
      <div class="rubric-progress" id="rubric-progress">
        <div class="progress-track"><div class="progress-fill"></div></div>
        <p class="progress-status" id="rubric-progress-status">{rubricLabels.processing}</p>
      </div>

      <!-- Rubric Preview -->
      <div class="rubric-preview" id="rubric-preview">
        <div class="rubric-info-banner">
          <div class="rubric-meta">
            <div class="rubric-meta-item">
              <span class="rubric-meta-label">{rubricLabels.document}</span>
              <span class="rubric-meta-value" id="rubric-doc-name">—</span>
            </div>
            <div class="rubric-meta-item">
              <span class="rubric-meta-label">{rubricLabels.criteria}</span>
              <span class="rubric-meta-value" id="rubric-criteria-count">—</span>
            </div>
            <div class="rubric-meta-item">
              <span class="rubric-meta-label">{rubricLabels.dimensions}</span>
              <span class="rubric-meta-value" id="rubric-dimensions-count">—</span>
            </div>
            <div class="rubric-meta-item">
              <span class="rubric-meta-label">{rubricLabels.totalWeight}</span>
              <span class="rubric-meta-value" id="rubric-total-weight">—</span>
            </div>
            <div class="rubric-meta-item">
              <span class="rubric-meta-label">{rubricLabels.method}</span>
              <span class="rubric-meta-value" style="color: #a78bfa;">🤖 {rubricLabels.multiAgent}</span>
            </div>
          </div>
        </div>

        <!-- Non-evaluable observations -->
        <div class="observations-panel" id="observations-panel" style="display:none;">
          <h3>{rubricLabels.nonEvaluableTitle}</h3>
          <div id="observations-container"></div>
        </div>

        <div id="rubric-dimensions-container"></div>
      </div>
    </div>
  </div>

  <div id="toast-container" class="toast-container"></div>

  <script is:inline src="/rubric.js"></script>
</body>
</html>
