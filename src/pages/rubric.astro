---
/**
 * Rubric Generator page — Multi-agent rubric generation.
 * Upload 2 PDFs (normative + evaluation schema) → multi-agent pipeline → preview → download PDF → clear.
 */
import UserSessionIsland from '../components/UserSessionIsland.astro';
import { t } from '../lib/i18n';

const currentLang = Astro.locals.lang || 'es';

// Local UI labels for self-contained translation block
const rubricLabels = {
  document: currentLang === 'en' ? 'Document' : currentLang === 'pt' ? 'Documento' : 'Documento',
  criteria: currentLang === 'en' ? 'Criteria' : currentLang === 'pt' ? 'Critérios' : 'Criterios',
  dimensions: currentLang === 'en' ? 'Dimensions' : currentLang === 'gl' ? 'Dimensións' : 'Dimensiones',
  totalWeight: currentLang === 'en' ? 'Total Weight' : currentLang === 'pt' ? 'Peso Total' : 'Peso Total',
  method: currentLang === 'en' ? 'Method' : currentLang === 'pt' ? 'Método' : 'Método',
  multiAgent: currentLang === 'en' ? 'Multi-Agent' : currentLang === 'gl' ? 'Multi-Axente' : 'Multi-Agente',
  nonEvaluableTitle: currentLang === 'en' ? '⚠️ Normative Aspects Not Included in the Rubric' : currentLang === 'gl' ? '⚠️ Aspectos Normativos Non Incluídos na Rúbrica' : currentLang === 'pt' ? '⚠️ Aspectos Normativos Não Incluídos na Rubrica' : '⚠️ Aspectos Normativos No Incluidos en la Rúbrica',
  processing: currentLang === 'en' ? 'Processing documents...' : currentLang === 'gl' ? 'Procesando documentos...' : currentLang === 'pt' ? 'Processando documentos...' : 'Procesando documentos...'
};

// Client-side mapping
const rubricTranslations = {
  executing_pipeline: t('rubric.js.executing_pipeline', currentLang),
  extracting_text: t('rubric.js.extracting_text', currentLang),
  extracting_ontology: t('rubric.js.extracting_ontology', currentLang),
  agent1_running: t('rubric.js.agent1_running', currentLang),
  agent2_running: t('rubric.js.agent2_running', currentLang),
  agent3_running: t('rubric.js.agent3_running', currentLang),
  rendering_preview: t('rubric.js.rendering_preview', currentLang),
  generate_success: t('rubric.js.generate_success', currentLang),
  clear_db_confirm: t('rubric.js.clear_db_confirm', currentLang),
  clearing: t('rubric.js.clearing', currentLang),
  clear_success: t('rubric.js.clear_success', currentLang),
  dimension: t('rubric.js.dimension', currentLang),
  component: t('rubric.js.component', currentLang),
  components: t('rubric.js.components', currentLang),
  table_evaluated_component: t('rubric.js.table.evaluated_component', currentLang),
  table_institutional_criterion: t('rubric.js.table.institutional_criterion', currentLang),
  table_level_excellent: t('rubric.js.table.level_excellent', currentLang),
  table_level_acceptable: t('rubric.js.table.level_acceptable', currentLang),
  table_level_insufficient: t('rubric.js.table.level_insufficient', currentLang),
  table_label_optimo: t('rubric.js.table.label_optimo', currentLang),
  table_label_acceptable: t('rubric.js.table.label_acceptable', currentLang),
  table_label_deficiente: t('rubric.js.table.label_deficiente', currentLang),
  reason: t('rubric.js.reason', currentLang),
  recommendation: t('rubric.js.recommendation', currentLang),
  pts_max: t('rubric.js.pts_max', currentLang),
  btn_generate: t('rubric.btn_generate', currentLang),
  btn_clear: t('rubric.btn_clear', currentLang)
};
---
<!DOCTYPE html>
<html lang={currentLang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Generador de rúbricas multi-agente para evaluación de guías docentes">
  <title>{t('rubric.title', currentLang)} — Knowledge Graph</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
  <style is:global>
    /* ── Rubric Page Layout ── */
    html, body {
      overflow-y: auto !important;
      height: auto !important;
    }
    .page-container {
      min-height: 100vh;
      padding-top: var(--top-bar-height);
    }
    .rubric-content {
      max-width: 1400px;
      margin: 0 auto;
      padding: 40px 24px 80px;
    }

    /* ── Hero ── */
    .page-hero {
      text-align: center;
      margin-bottom: 48px;
    }
    .multi-agent-badge {
      display: inline-block;
      padding: 6px 14px;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--accent-violet);
      background: rgba(139, 92, 246, 0.08);
      border: 1px solid rgba(139, 92, 246, 0.2);
      border-radius: var(--radius-full);
      margin-bottom: 16px;
      box-shadow: 0 2px 10px rgba(139, 92, 246, 0.05);
    }
    .page-hero h1 {
      font-size: 2.6rem;
      font-weight: 800;
      background: linear-gradient(135deg, var(--accent-violet), var(--accent-cyan));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 12px;
      letter-spacing: -0.02em;
    }
    .page-hero p {
      color: var(--text-secondary);
      font-size: 1.05rem;
      max-width: 720px;
      margin: 0 auto;
      line-height: 1.6;
    }

    /* ── Steps timeline ── */
    .rubric-steps {
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: var(--bg-secondary);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-lg);
      padding: 24px 32px;
      margin-bottom: 40px;
      gap: 16px;
      box-shadow: var(--shadow-md);
      position: relative;
    }
    .rubric-step {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
      position: relative;
      flex: 1;
      color: var(--text-muted);
      font-size: 0.85rem;
      font-weight: 600;
      transition: all var(--transition-normal);
      z-index: 2;
    }
    .step-num {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: var(--bg-tertiary);
      border: 2px solid var(--border-light);
      color: var(--text-secondary);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.9rem;
      font-weight: 700;
      transition: all var(--transition-normal);
      z-index: 2;
    }
    /* Horizontal progress lines between steps */
    .rubric-step::after {
      content: '';
      position: absolute;
      top: 18px; /* half of 36px */
      left: calc(50% + 18px);
      width: calc(100% - 36px);
      height: 2px;
      background: var(--border-light);
      z-index: 1;
      transition: background var(--transition-normal);
    }
    .rubric-step:last-child::after {
      display: none;
    }
    .rubric-step.active {
      color: var(--text-primary);
    }
    .rubric-step.active .step-num {
      background: linear-gradient(135deg, var(--accent-violet), var(--accent-cyan));
      color: white;
      border-color: transparent;
      box-shadow: 0 0 16px var(--accent-violet-glow);
    }
    .rubric-step.done {
      color: var(--accent-emerald);
    }
    .rubric-step.done .step-num {
      background: var(--accent-emerald);
      color: white;
      border-color: transparent;
      box-shadow: 0 0 12px rgba(16, 185, 129, 0.2);
    }
    .rubric-step.done::after {
      background: var(--accent-emerald);
    }

    /* ── Upload Cards ── */
    .upload-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      margin-bottom: 40px;
    }
    .upload-card-rubric {
      background: var(--bg-secondary);
      border: 2px dashed var(--border-light);
      border-radius: var(--radius-lg);
      padding: 40px 32px;
      text-align: center;
      transition: all var(--transition-normal);
      cursor: pointer;
      position: relative;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 12px;
      box-shadow: var(--shadow-sm);
    }
    .upload-card-rubric:hover {
      border-color: var(--accent-violet);
      background: var(--bg-elevated);
      transform: translateY(-2px);
      box-shadow: var(--shadow-glow-violet);
    }
    .upload-card-rubric input[type="file"] {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      border: 0;
    }
    .upload-icon {
      font-size: 3rem;
      line-height: 1;
      transition: transform var(--transition-normal);
    }
    .upload-card-rubric:hover .upload-icon {
      transform: scale(1.1);
    }
    .upload-card-rubric h3 {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--text-primary);
    }
    .upload-card-rubric p.upload-hint {
      font-size: 0.85rem;
      color: var(--text-secondary);
      line-height: 1.5;
      max-width: 320px;
    }
    .upload-filename-rubric {
      margin-top: 8px;
      font-size: 0.88rem;
      font-weight: 600;
      color: var(--accent-emerald);
      background: rgba(16, 185, 129, 0.1);
      border: 1px solid rgba(16, 185, 129, 0.2);
      padding: 8px 16px;
      border-radius: var(--radius-md);
      display: inline-flex;
      align-items: center;
      gap: 8px;
      max-width: 90%;
      word-break: break-all;
    }
    .upload-card-rubric.has-file {
      border-color: var(--accent-emerald);
      border-style: solid;
      background: rgba(16, 185, 129, 0.02);
      box-shadow: 0 0 24px rgba(16, 185, 129, 0.05);
    }
    .upload-card-rubric.has-file:hover {
      border-color: #059669;
      background: rgba(16, 185, 129, 0.04);
      box-shadow: 0 0 28px rgba(16, 185, 129, 0.1);
    }

    /* ── Options / Selector ── */
    .options-container {
      display: flex;
      justify-content: center;
      margin-bottom: 32px;
    }
    .options-box {
      display: flex;
      align-items: center;
      gap: 16px;
      background: var(--bg-secondary);
      padding: 12px 24px;
      border-radius: var(--radius-md);
      border: 1px solid var(--border-subtle);
      box-shadow: var(--shadow-md);
    }
    .options-label {
      font-size: 0.88rem;
      color: var(--text-secondary);
      font-weight: 600;
    }
    .options-select {
      background: var(--bg-primary);
      border: 1px solid var(--border-light);
      padding: 8px 16px;
      border-radius: var(--radius-sm);
      color: var(--text-primary);
      font-family: var(--font-sans);
      font-size: 0.88rem;
      cursor: pointer;
      outline: none;
      transition: all var(--transition-fast);
    }
    .options-select:hover, .options-select:focus {
      border-color: var(--accent-violet);
      box-shadow: 0 0 0 2px var(--accent-violet-glow);
    }

    /* ── Actions ── */
    .rubric-actions {
      display: flex;
      justify-content: center;
      gap: 16px;
      margin-bottom: 40px;
    }
    .btn-generate {
      padding: 14px 40px;
      font-size: 1rem;
      border-radius: var(--radius-md);
      background: linear-gradient(135deg, var(--accent-violet), #7C3AED);
      color: white;
      border: none;
      font-weight: 700;
      font-family: var(--font-sans);
      cursor: pointer;
      transition: all var(--transition-fast);
      box-shadow: var(--shadow-glow-violet);
    }
    .btn-generate:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 0 36px rgba(139, 92, 246, 0.35);
    }
    .btn-generate:disabled {
      opacity: 0.4;
      cursor: not-allowed;
      transform: none;
    }
    .btn-download-rubric {
      display: none;
      align-items: center;
      justify-content: center;
      padding: 14px 32px;
      font-size: 1rem;
      border-radius: var(--radius-md);
      background: linear-gradient(135deg, var(--accent-emerald), #059669);
      color: white;
      text-decoration: none;
      font-weight: 700;
      transition: all var(--transition-fast);
      box-shadow: 0 0 20px rgba(16, 185, 129, 0.2);
    }
    .btn-download-rubric:hover {
      transform: translateY(-2px);
      box-shadow: 0 0 32px rgba(16, 185, 129, 0.35);
    }
    .btn-clear-rubric {
      display: none;
      padding: 14px 32px;
      font-size: 1rem;
      border-radius: var(--radius-md);
      background: linear-gradient(135deg, var(--accent-rose), #e11d48);
      color: white;
      border: none;
      font-weight: 700;
      cursor: pointer;
      transition: all var(--transition-fast);
      box-shadow: 0 0 20px rgba(244, 63, 94, 0.15);
    }
    .btn-clear-rubric:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 0 32px rgba(244, 63, 94, 0.35);
    }
    .btn-clear-rubric:disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }

    /* ── Progress Card ── */
    .rubric-progress {
      display: none;
      margin: 0 auto 40px;
      max-width: 600px;
      background: var(--bg-secondary);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-lg);
      padding: 32px;
      box-shadow: var(--shadow-lg);
      text-align: center;
    }
    .rubric-progress.active {
      display: block;
      animation: fadeIn var(--transition-normal);
    }
    .progress-spinner {
      width: 40px;
      height: 40px;
      border: 3px solid rgba(139, 92, 246, 0.1);
      border-top-color: var(--accent-violet);
      border-radius: 50%;
      margin: 0 auto 16px;
      animation: spin 1s linear infinite;
    }
    .progress-track {
      height: 6px;
      background: var(--bg-tertiary);
      border-radius: var(--radius-full);
      overflow: hidden;
      margin-top: 16px;
    }
    .progress-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--accent-violet), var(--accent-cyan));
      border-radius: var(--radius-full);
      width: 40%;
      animation: progressSlide 1.5s ease-in-out infinite;
    }
    @keyframes progressSlide {
      0% { transform: translateX(-100%); }
      100% { transform: translateX(250%); }
    }
    @keyframes spin {
      to { transform: rotate(360deg); }
    }
    .progress-status {
      font-size: 0.9rem;
      color: var(--text-secondary);
      margin-top: 12px;
      font-weight: 500;
    }

    /* ── Preview Section ── */
    .rubric-preview {
      display: none;
      animation: fadeIn var(--transition-normal) forwards;
    }
    .rubric-preview.visible {
      display: block;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* ── Rubric Info Banner ── */
    .rubric-info-banner {
      background: var(--bg-glass);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-lg);
      padding: 24px;
      margin-bottom: 40px;
      box-shadow: var(--shadow-md);
    }
    .rubric-meta {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 20px;
    }
    .rubric-meta-item {
      display: flex;
      flex-direction: column;
      gap: 6px;
      padding: 0 16px;
      border-right: 1px solid var(--border-light);
    }
    .rubric-meta-item:last-child {
      border-right: none;
    }
    .rubric-meta-label {
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-muted);
    }
    .rubric-meta-value {
      font-size: 1.15rem;
      font-weight: 800;
      color: var(--text-primary);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* ── Observations Panel ── */
    .observations-panel {
      background: rgba(245, 158, 11, 0.03);
      border: 1px solid rgba(245, 158, 11, 0.2);
      border-radius: var(--radius-lg);
      padding: 28px;
      margin-bottom: 40px;
      box-shadow: var(--shadow-sm);
    }
    .observations-panel h3 {
      font-size: 1rem;
      font-weight: 800;
      color: var(--accent-amber);
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .observation-item {
      padding: 16px 20px;
      background: var(--bg-secondary);
      border-left: 4px solid var(--accent-amber);
      border-radius: var(--radius-md);
      margin-bottom: 16px;
      box-shadow: var(--shadow-sm);
    }
    .observation-item:last-child {
      margin-bottom: 0;
    }
    .observation-item strong {
      font-size: 0.95rem;
      color: var(--text-primary);
      display: block;
      margin-bottom: 8px;
      font-weight: 700;
    }
    .observation-item p {
      font-size: 0.88rem;
      color: var(--text-secondary);
      margin-bottom: 6px;
      line-height: 1.6;
    }
    .observation-item p:last-child {
      margin-bottom: 0;
    }
    .observation-item em {
      color: var(--accent-amber);
      font-style: normal;
      font-weight: 700;
      text-transform: uppercase;
      font-size: 0.72rem;
      letter-spacing: 0.04em;
      margin-right: 6px;
    }

    /* ── Dimension Sections & Tables ── */
    .dimension-section {
      background: var(--bg-secondary);
      border: 1px solid var(--border-light);
      border-radius: var(--radius-lg);
      margin-bottom: 40px;
      overflow: hidden;
      box-shadow: var(--shadow-md);
      transition: border-color var(--transition-normal);
    }
    .dimension-section:hover {
      border-color: rgba(139, 92, 246, 0.2);
    }
    .dimension-header {
      padding: 20px 24px;
      background: linear-gradient(90deg, var(--bg-tertiary), rgba(31, 41, 55, 0.3));
      border-bottom: 1px solid var(--border-light);
      display: flex;
      align-items: center;
      gap: 12px;
      position: relative;
    }
    .dimension-header::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 4px;
      background: linear-gradient(180deg, var(--accent-violet), var(--accent-cyan));
    }
    .dimension-icon {
      font-size: 1.25rem;
    }
    .dimension-name {
      font-size: 0.98rem;
      font-weight: 800;
      color: var(--text-primary);
      letter-spacing: 0.03em;
    }
    .dimension-count {
      margin-left: auto;
      font-size: 0.75rem;
      font-weight: 700;
      color: var(--accent-cyan);
      background: rgba(6, 182, 212, 0.1);
      border: 1px solid rgba(6, 182, 212, 0.2);
      padding: 4px 12px;
      border-radius: var(--radius-full);
    }

    /* ── Criteria Table Layout ── */
    .criteria-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      font-size: 0.88rem;
    }
    .criteria-table th {
      padding: 16px 20px;
      text-align: left;
      font-weight: 700;
      font-size: 0.8rem;
      color: var(--text-primary);
      border-bottom: 2px solid var(--border-light);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .criteria-table td {
      padding: 20px;
      vertical-align: top;
      border-bottom: 1px solid var(--border-subtle);
      line-height: 1.6;
      transition: background var(--transition-fast);
    }
    .criteria-table tr:hover td {
      background-color: rgba(255, 255, 255, 0.01) !important;
    }
    .criteria-table tr:last-child td {
      border-bottom: none;
    }
    .th-criterion {
      background: rgba(255, 255, 255, 0.02);
    }
    .th-excellent {
      background: rgba(16, 185, 129, 0.04);
      color: var(--accent-emerald) !important;
      border-bottom-color: rgba(16, 185, 129, 0.2) !important;
    }
    .th-acceptable {
      background: rgba(245, 158, 11, 0.04);
      color: var(--accent-amber) !important;
      border-bottom-color: rgba(245, 158, 11, 0.2) !important;
    }
    .th-insufficient {
      background: rgba(244, 63, 94, 0.04);
      color: var(--accent-rose) !important;
      border-bottom-color: rgba(244, 63, 94, 0.2) !important;
    }
    .td-criterion {
      font-weight: 500;
      color: var(--text-primary);
      background: rgba(255, 255, 255, 0.01);
    }
    .td-criterion strong {
      font-size: 0.95rem;
      font-weight: 700;
      display: block;
      margin-top: 6px;
      color: var(--text-primary);
    }
    .td-institutional {
      color: var(--text-secondary);
      font-size: 0.85rem;
      background: rgba(255, 255, 255, 0.005);
      border-left: 1px solid var(--border-subtle);
    }
    .td-excellent {
      background: rgba(16, 185, 129, 0.01);
      color: var(--text-secondary);
      border-left: 1px solid rgba(16, 185, 129, 0.15);
    }
    .td-excellent strong {
      color: var(--accent-emerald);
      display: block;
      margin-bottom: 8px;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.06em;
    }
    .td-acceptable {
      background: rgba(245, 158, 11, 0.01);
      color: var(--text-secondary);
      border-left: 1px solid rgba(245, 158, 11, 0.15);
    }
    .td-acceptable strong {
      color: var(--accent-amber);
      display: block;
      margin-bottom: 8px;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.06em;
    }
    .td-insufficient {
      background: rgba(244, 63, 94, 0.01);
      color: var(--text-secondary);
      border-left: 1px solid rgba(244, 63, 94, 0.15);
    }
    .td-insufficient strong {
      color: var(--accent-rose);
      display: block;
      margin-bottom: 8px;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.06em;
    }

    /* ── Responsive ── */
    @media (max-width: 1024px) {
      .rubric-steps {
        padding: 20px;
      }
      .rubric-meta {
        grid-template-columns: repeat(3, 1fr);
      }
      .rubric-meta-item:nth-child(3) {
        border-right: none;
      }
    }
    @media (max-width: 768px) {
      .upload-grid {
        grid-template-columns: 1fr;
        gap: 16px;
      }
      .rubric-steps {
        flex-direction: column;
        align-items: flex-start;
        gap: 16px;
        padding: 20px;
      }
      .rubric-step {
        flex-direction: row;
        text-align: left;
        min-width: unset;
        width: 100%;
        gap: 12px;
      }
      .rubric-step::after {
        display: none;
      }
      .rubric-actions {
        flex-direction: column;
        align-items: stretch;
      }
      .rubric-meta {
        grid-template-columns: 1fr;
        gap: 12px;
      }
      .rubric-meta-item {
        border-right: none;
        border-bottom: 1px solid var(--border-light);
        padding: 0 0 10px 0;
      }
      .rubric-meta-item:last-child {
        border-bottom: none;
        padding-bottom: 0;
      }

      /* Responsive Rubric Table to Cards */
      .criteria-table, .criteria-table thead, .criteria-table tbody, .criteria-table th, .criteria-table td, .criteria-table tr {
        display: block;
      }
      .criteria-table thead {
        display: none;
      }
      .criteria-table tr {
        border-bottom: 2px solid var(--border-light);
        padding: 16px 0;
      }
      .criteria-table tr:last-child {
        border-bottom: none;
      }
      .criteria-table td {
        border: none !important;
        background: transparent !important;
        padding: 10px 16px;
        width: 100% !important;
      }
      .criteria-table td::before {
        content: attr(data-label);
        font-weight: 700;
        display: block;
        margin-bottom: 6px;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--text-muted);
      }
      .criteria-table td.td-criterion {
        background: rgba(255, 255, 255, 0.02) !important;
        border-radius: var(--radius-md) !important;
        padding: 16px !important;
        margin-bottom: 8px;
      }
      .criteria-table td.td-criterion::before {
        margin-bottom: 4px;
      }
      .criteria-table td.td-excellent, .criteria-table td.td-acceptable, .criteria-table td.td-insufficient {
        border-left: 3px solid transparent !important;
        margin-bottom: 8px;
        border-radius: var(--radius-sm);
      }
      .criteria-table td.td-excellent {
        background: rgba(16, 185, 129, 0.02) !important;
        border-left-color: var(--accent-emerald) !important;
      }
      .criteria-table td.td-acceptable {
        background: rgba(245, 158, 11, 0.02) !important;
        border-left-color: var(--accent-amber) !important;
      }
      .criteria-table td.td-insufficient {
        background: rgba(244, 63, 94, 0.02) !important;
        border-left-color: var(--accent-rose) !important;
      }
    }
  </style>
  <script is:inline define:vars={{ rubricTranslations }}>
    window.AppTranslations = rubricTranslations;
  </script>
</head>
<body>
  <!-- Top Bar -->
  <header id="top-bar" class="top-bar">
    <div class="top-bar-left">
      <div class="logo">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
          <circle cx="14" cy="14" r="12" stroke="url(#logo-grad-r)" stroke-width="2.5" fill="none"/>
          <circle cx="8" cy="11" r="2.5" fill="#8B5CF6"/>
          <circle cx="18" cy="9" r="2.5" fill="#06B6D4"/>
          <circle cx="15" cy="19" r="2.5" fill="#F59E0B"/>
          <line x1="8" y1="11" x2="18" y2="9" stroke="#8B5CF680" stroke-width="1.5"/>
          <line x1="18" y1="9" x2="15" y2="19" stroke="#06B6D480" stroke-width="1.5"/>
          <line x1="8" y1="11" x2="15" y2="19" stroke="#F59E0B80" stroke-width="1.5"/>
          <defs><linearGradient id="logo-grad-r" x1="0" y1="0" x2="28" y2="28"><stop stop-color="#8B5CF6"/><stop offset="1" stop-color="#06B6D4"/></linearGradient></defs>
        </svg>
        <span class="logo-text">Knowledge Graph</span>
      </div>
    </div>
    <div class="top-bar-right" style="display:flex; align-items:center; gap:12px;">
      <a href="/compare" class="nav-link">📊 {t('nav.compare', currentLang)}</a>
      <a href="/" class="nav-link">← {t('rubric.back_to_graph', currentLang)}</a>
      
      <UserSessionIsland server:defer>
        <div slot="fallback" style="color: #9ca3af; font-size: 0.75rem; padding: 6px 12px; background: rgba(255,255,255,0.05); border-radius:8px; border:1px solid rgba(255,255,255,0.08); min-width: 120px; text-align: center;">{t('loading', currentLang)}</div>
      </UserSessionIsland>
    </div>
  </header>

  <div class="page-container">
    <div class="rubric-content">
      <!-- Hero -->
      <div class="page-hero">
        <span class="multi-agent-badge">{t('rubric.system_badge', currentLang)}</span>
        <h1>📝 {t('rubric.title', currentLang)}</h1>
        <p>{t('rubric.subtitle', currentLang)}</p>
      </div>

      <!-- Steps indicator (5 steps) -->
      <div class="rubric-steps" id="rubric-steps">
        <div class="rubric-step" id="step-upload">
          <span class="step-num">1</span>
          <span>{t('rubric.step1', currentLang)}</span>
        </div>
        <div class="rubric-step" id="step-extract">
          <span class="step-num">2</span>
          <span>{t('rubric.step2', currentLang)}</span>
        </div>
        <div class="rubric-step" id="step-ontology-agent">
          <span class="step-num">3</span>
          <span>{t('rubric.step3', currentLang)}</span>
        </div>
        <div class="rubric-step" id="step-adjuster-agent">
          <span class="step-num">4</span>
          <span>{t('rubric.step4', currentLang)}</span>
        </div>
        <div class="rubric-step" id="step-synthesizer-agent">
          <span class="step-num">5</span>
          <span>{t('rubric.step5', currentLang)}</span>
        </div>
      </div>

      <!-- Upload Cards (2) -->
      <div class="upload-grid" id="upload-section">
        <!-- Normative PDF -->
        <div class="upload-card-rubric" data-type="normative" id="card-normative-rubric">
          <input type="file" accept=".pdf" id="file-normative-rubric" style="display: none;">
          <span class="upload-icon">📋</span>
          <h3>{t('rubric.normative_title', currentLang)}</h3>
          <p class="upload-hint">{t('rubric.normative_desc', currentLang)}</p>
          <p class="upload-filename-rubric" id="name-normative-rubric"></p>
        </div>

        <!-- Evaluation Schema PDF -->
        <div class="upload-card-rubric" data-type="schema" id="card-schema-rubric">
          <input type="file" accept=".pdf" id="file-schema-rubric" style="display: none;">
          <span class="upload-icon">📐</span>
          <h3>{t('rubric.schema_title', currentLang)}</h3>
          <p class="upload-hint">{t('rubric.schema_desc', currentLang)}</p>
          <p class="upload-filename-rubric" id="name-schema-rubric"></p>
        </div>
      </div>

      <!-- IA Provider Options -->
      <div class="options-container">
        <div class="options-box">
          <label class="options-label" for="model-provider">{t('rubric.ai_provider', currentLang)}</label>
          <select id="model-provider" class="options-select">
            <option value="gemini">Google Gemini (Gemini 2.5 Flash)</option>
            <option value="groq">Groq Llama 3.3 (70B - Preciso)</option>
            <option value="groq-fast">Groq Llama 3.1 (8B - Rápido)</option>
          </select>
        </div>
      </div>

      <!-- Actions -->
      <div class="rubric-actions" id="rubric-actions">
        <button id="btn-generate-rubric" class="btn-generate" disabled>
          {t('rubric.btn_generate', currentLang)}
        </button>
        <a id="btn-download-rubric" class="btn-download-rubric" download="rubrica.pdf">
          {t('rubric.btn_download', currentLang)}
        </a>
        <button id="btn-clear-rubric" class="btn-clear-rubric">
          {t('rubric.btn_clear', currentLang)}
        </button>
      </div>

      <!-- Progress -->
      <div class="rubric-progress" id="rubric-progress">
        <div class="progress-spinner"></div>
        <div class="progress-track"><div class="progress-fill"></div></div>
        <p class="progress-status" id="rubric-progress-status">{rubricLabels.processing}</p>
      </div>

      <!-- Rubric Preview -->
      <div class="rubric-preview" id="rubric-preview">
        <div class="rubric-info-banner">
          <div class="rubric-meta">
            <div class="rubric-meta-item">
              <span class="rubric-meta-label">{rubricLabels.document}</span>
              <span class="rubric-meta-value" id="rubric-doc-name">—</span>
            </div>
            <div class="rubric-meta-item">
              <span class="rubric-meta-label">{rubricLabels.criteria}</span>
              <span class="rubric-meta-value" id="rubric-criteria-count">—</span>
            </div>
            <div class="rubric-meta-item">
              <span class="rubric-meta-label">{rubricLabels.dimensions}</span>
              <span class="rubric-meta-value" id="rubric-dimensions-count">—</span>
            </div>
            <div class="rubric-meta-item">
              <span class="rubric-meta-label">{rubricLabels.totalWeight}</span>
              <span class="rubric-meta-value" id="rubric-total-weight">—</span>
            </div>
            <div class="rubric-meta-item">
              <span class="rubric-meta-label">{rubricLabels.method}</span>
              <span class="rubric-meta-value" style="color: #a78bfa;">🤖 {rubricLabels.multiAgent}</span>
            </div>
          </div>
        </div>

        <!-- Non-evaluable observations -->
        <div class="observations-panel" id="observations-panel" style="display:none;">
          <h3>{rubricLabels.nonEvaluableTitle}</h3>
          <div id="observations-container"></div>
        </div>

        <div id="rubric-dimensions-container"></div>
      </div>
    </div>
  </div>

  <div id="toast-container" class="toast-container"></div>

  <script is:inline src="/rubric.js"></script>
</body>
</html>
