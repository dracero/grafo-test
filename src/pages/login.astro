---
import { t } from '../lib/i18n';

const currentLang = Astro.locals.lang || 'es';

const continueWithGoogle = currentLang === 'en' ? 'Continue with Google' : currentLang === 'pt' ? 'Continuar com o Google' : 'Continuar con Google';
const continueWithMicrosoft = currentLang === 'en' ? 'Continue with Microsoft' : currentLang === 'pt' ? 'Continuar com a Microsoft' : 'Continuar con Microsoft';
const orText = currentLang === 'en' ? 'Or' : currentLang === 'pt' ? 'Ou' : 'O';

const adminNotice = currentLang === 'es' 
  ? 'ℹ️ El primer usuario registrado/logueado será el Administrador (activo inmediatamente). Los siguientes se crearán como inactivos y requerirán aprobación.'
  : currentLang === 'gl'
  ? 'ℹ️ O primeiro usuario rexistrado/logueado será o Administrador (activo inmediatamente). Os seguintes crearanse como inactivos e requirirán aprobación.'
  : currentLang === 'pt'
  ? 'ℹ️ O primeiro usuário registrado/logado será o Administrador (ativo imediatamente). Os seguintes serão criados como inativos e exigirão aprovação.'
  : 'ℹ️ The first user registered/logged in will be the Administrator (active immediately). Subsequent users will be created as inactive and require approval.';
---

<!DOCTYPE html>
<html lang={currentLang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{t('login_title', currentLang)}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
  <style>
    body {
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      background: radial-gradient(circle at 10% 20%, rgb(17, 17, 17) 0%, rgb(10, 10, 10) 90.1%);
      margin: 0;
      font-family: 'Inter', sans-serif;
    }

    .login-container {
      width: 100%;
      max-width: 440px;
      padding: 40px;
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 16px;
      backdrop-filter: blur(10px);
      box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.5);
      text-align: center;
      animation: fadeIn 0.6s ease-out;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .logo-container {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 10px;
      margin-bottom: 24px;
    }

    .logo-text {
      font-size: 1.5rem;
      font-weight: 800;
      letter-spacing: -0.5px;
      background: linear-gradient(135deg, #8B5CF6, #06B6D4);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    h2 {
      color: #f3f4f6;
      font-size: 1.25rem;
      margin-bottom: 8px;
      font-weight: 600;
    }

    p.subtitle {
      color: #9ca3af;
      font-size: 0.875rem;
      margin-bottom: 24px;
    }

    .info-banner {
      margin-bottom: 24px;
      padding: 12px;
      background: rgba(139, 92, 246, 0.1);
      border: 1px solid rgba(139, 92, 246, 0.25);
      border-radius: 8px;
      color: #c084fc;
      font-size: 0.82rem;
      text-align: left;
      line-height: 1.4;
    }

    .form-group {
      text-align: left;
      margin-bottom: 20px;
    }

    label {
      display: block;
      color: #9ca3af;
      font-size: 0.75rem;
      font-weight: 600;
      margin-bottom: 8px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .input-field {
      width: 100%;
      padding: 12px 16px;
      background: rgba(0, 0, 0, 0.4);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      color: #f3f4f6;
      font-size: 0.9rem;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .input-field:focus {
      border-color: #8b5cf6;
      box-shadow: 0 0 0 2px rgba(139, 92, 246, 0.2);
    }

    .btn-submit {
      width: 100%;
      padding: 14px;
      background: linear-gradient(135deg, #8B5CF6, #6D28D9);
      border: none;
      border-radius: 8px;
      color: white;
      font-weight: 600;
      font-size: 0.95rem;
      cursor: pointer;
      transition: transform 0.15s, opacity 0.2s;
      box-shadow: 0 4px 12px rgba(139, 92, 246, 0.3);
      margin-top: 10px;
    }

    .btn-submit:hover {
      transform: translateY(-1px);
      opacity: 0.95;
    }

    .btn-submit:active {
      transform: translateY(0);
    }

    .error-box {
      margin-bottom: 20px;
      padding: 12px;
      background: rgba(239, 68, 68, 0.1);
      border: 1px solid rgba(239, 68, 68, 0.2);
      border-radius: 8px;
      color: #fca5a5;
      font-size: 0.85rem;
      display: none;
      text-align: left;
    }

    .link-container {
      margin-top: 24px;
      font-size: 0.85rem;
    }

    .link-container a {
      color: #a78bfa;
      text-decoration: none;
      font-weight: 500;
      transition: color 0.2s;
    }

    .link-container a:hover {
      color: #c084fc;
      text-decoration: underline;
    }

    /* OAuth Styles */
    .oauth-buttons {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-bottom: 20px;
    }

    .btn-oauth {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      width: 100%;
      padding: 12px;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 8px;
      color: #e5e7eb;
      font-weight: 500;
      font-size: 0.9rem;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.2s;
    }

    .btn-oauth:hover {
      background: rgba(255, 255, 255, 0.06);
      border-color: rgba(255, 255, 255, 0.15);
      color: #fff;
      transform: translateY(-1px);
    }

    .btn-oauth:active {
      transform: translateY(0);
    }

    .oauth-divider {
      display: flex;
      align-items: center;
      margin: 20px 0;
      color: #6b7280;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .oauth-divider::before, .oauth-divider::after {
      content: "";
      flex: 1;
      height: 1px;
      background: rgba(255, 255, 255, 0.08);
    }

    .oauth-divider::before { margin-right: 12px; }
    .oauth-divider::after { margin-left: 12px; }

    /* Lang switcher inside login */
    .lang-switcher-login {
      margin-top: 32px;
      display: flex;
      justify-content: center;
      gap: 12px;
      border-top: 1px solid rgba(255, 255, 255, 0.05);
      padding-top: 20px;
    }

    .lang-btn {
      background: transparent;
      border: none;
      color: #6b7280;
      font-size: 0.75rem;
      cursor: pointer;
      transition: color 0.2s;
    }

    .lang-btn.active, .lang-btn:hover {
      color: #e5e7eb;
      font-weight: 600;
    }
  </style>
</head>
<body>
  <div class="login-container">
    <div class="logo-container">
      <svg width="32" height="32" viewBox="0 0 28 28" fill="none">
        <circle cx="14" cy="14" r="12" stroke="url(#logo-grad)" stroke-width="2.5" fill="none"/>
        <circle cx="8" cy="11" r="2.5" fill="#8B5CF6"/>
        <circle cx="18" cy="9" r="2.5" fill="#06B6D4"/>
        <circle cx="15" cy="19" r="2.5" fill="#F59E0B"/>
        <line x1="8" y1="11" x2="18" y2="9" stroke="#8B5CF680" stroke-width="1.5"/>
        <line x1="18" y1="9" x2="15" y2="19" stroke="#06B6D480" stroke-width="1.5"/>
        <line x1="8" y1="11" x2="15" y2="19" stroke="#F59E0B80" stroke-width="1.5"/>
        <defs><linearGradient id="logo-grad" x1="0" y1="0" x2="28" y2="28"><stop stop-color="#8B5CF6"/><stop offset="1" stop-color="#06B6D4"/></linearGradient></defs>
      </svg>
      <span class="logo-text">Knowledge Graph</span>
    </div>

    <h2>{t('login_title', currentLang)}</h2>
    <p class="subtitle">{t('login_subtitle', currentLang)}</p>

    <div class="info-banner">
      {adminNotice}
    </div>

    <div id="error-box" class="error-box"></div>

    <div class="oauth-buttons">
      <a href="/api/auth/login/google" class="btn-oauth">
        <!-- Google Icon -->
        <svg width="18" height="18" viewBox="0 0 24 24">
          <path fill="#4285F4" d="M23.745 12.27c0-.7-.06-1.4-.19-2.07H12v3.927h6.6c-.285 1.5-1.14 2.78-2.42 3.63v3.006h3.9c2.28-2.1 3.665-5.19 3.665-8.797z"/>
          <path fill="#34A853" d="M12 24c3.24 0 5.95-1.08 7.93-2.91l-3.9-3.006c-1.08.72-2.45 1.16-4.03 1.16-3.11 0-5.74-2.11-6.68-4.96H1.21v3.11C3.18 21.88 7.39 24 12 24z"/>
          <path fill="#FBBC05" d="M5.32 14.284a7.16 7.16 0 0 1 0-4.568V6.606H1.21a11.99 11.99 0 0 0 0 10.787l4.11-3.11z"/>
          <path fill="#EA4335" d="M12 4.75c1.77 0 3.35.61 4.6 1.8l3.43-3.43C17.95 1.19 15.24 0 12 0 7.39 0 3.18 2.12 1.21 6.606l4.11 3.11c.94-2.85 3.57-4.966 6.68-4.966z"/>
        </svg>
        <span>{continueWithGoogle}</span>
      </a>
      <a href="/api/auth/login/microsoft" class="btn-oauth">
        <!-- Microsoft Icon -->
        <svg width="18" height="18" viewBox="0 0 23 23">
          <path fill="#f35325" d="M0 0h11v11H0z"/>
          <path fill="#81bc06" d="M12 0h11v11H12z"/>
          <path fill="#05a6f0" d="M0 12h11v11H0z"/>
          <path fill="#ffba08" d="M12 12h11v11H12z"/>
        </svg>
        <span>{continueWithMicrosoft}</span>
      </a>
    </div>

    <div class="oauth-divider">
      {orText}
    </div>

    <form id="login-form">
      <div class="form-group">
        <label for="email">{t('email', currentLang)}</label>
        <input type="email" id="email" class="input-field" required placeholder="tu@email.com" autocomplete="email">
      </div>
      <div class="form-group">
        <label for="password">{t('password', currentLang)}</label>
        <input type="password" id="password" class="input-field" required placeholder="••••••••" autocomplete="current-password">
      </div>

      <button type="submit" id="btn-submit" class="btn-submit">
        {t('login_button', currentLang)}
      </button>
    </form>

    <div class="link-container">
      <a href="/register">{t('dont_have_account', currentLang)}</a>
    </div>

    <div class="lang-switcher-login">
      <button class={`lang-btn ${currentLang === 'es' ? 'active' : ''}`} data-lang="es">ES</button>
      <button class={`lang-btn ${currentLang === 'gl' ? 'active' : ''}`} data-lang="gl">GL</button>
      <button class={`lang-btn ${currentLang === 'en' ? 'active' : ''}`} data-lang="en">EN</button>
      <button class={`lang-btn ${currentLang === 'pt' ? 'active' : ''}`} data-lang="pt">PT</button>
    </div>
  </div>

  <script>
    // Handles login form submission
    const form = document.getElementById('login-form') as HTMLFormElement;
    const errorBox = document.getElementById('error-box') as HTMLDivElement;
    const btnSubmit = document.getElementById('btn-submit') as HTMLButtonElement;

    // Show error from URL if present
    const urlParams = new URLSearchParams(window.location.search);
    const urlError = urlParams.get('error');
    if (urlError) {
      if (urlError === 'role_pending') {
        errorBox.textContent = 'Tu cuenta está pendiente de aprobación por el administrador.';
      } else if (urlError === 'account_disabled') {
        errorBox.textContent = 'Tu cuenta ha sido desactivada por un administrador.';
      } else {
        errorBox.textContent = 'Error de autenticación: ' + decodeURIComponent(urlError);
      }
      errorBox.style.display = 'block';
    }

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorBox.style.display = 'none';
      btnSubmit.disabled = true;
      btnSubmit.textContent = '...';

      const email = (document.getElementById('email') as HTMLInputElement).value;
      const password = (document.getElementById('password') as HTMLInputElement).value;

      try {
        const res = await fetch('/api/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password })
        });
        const data = await res.json();

        if (res.ok && data.success) {
          window.location.href = '/';
        } else {
          errorBox.textContent = data.error || 'Error de autenticación';
          errorBox.style.display = 'block';
        }
      } catch (err) {
        errorBox.textContent = 'Error de conexión con el servidor';
        errorBox.style.display = 'block';
      } finally {
        btnSubmit.disabled = false;
        btnSubmit.textContent = 'Iniciar sesión';
      }
    });

    // Language switcher click handlers
    document.querySelectorAll('.lang-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const newLang = (e.target as HTMLButtonElement).dataset.lang;
        if (newLang) {
          const res = await fetch('/api/auth/lang', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ lang: newLang })
          });
          if (res.ok) {
            window.location.reload();
          }
        }
      });
    });
  </script>
</body>
</html>
