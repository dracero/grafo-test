---
import { t } from '../lib/i18n';

const currentLang = Astro.locals.lang || 'es';

const adminNotice = currentLang === 'es' 
  ? 'ℹ️ El primer usuario registrado será el Administrador (activo inmediatamente). Los siguientes se registrarán como inactivos y requerirán su aprobación para ingresar.'
  : currentLang === 'gl'
  ? 'ℹ️ O primeiro usuario rexistrado será o Administrador (activo inmediatamente). Os seguintes rexistraranse como inactivos e requirirán a súa aprobación para ingresar.'
  : currentLang === 'pt'
  ? 'ℹ️ O primeiro usuário registrado será o Administrador (ativo imediatamente). Os seguintes se registrarão como inativos e exigirão sua aprovação para entrar.'
  : 'ℹ️ The first user registered will be the Administrator (active immediately). Subsequent accounts will be registered as inactive and require their approval to log in.';
---

<!DOCTYPE html>
<html lang={currentLang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{t('register_title', currentLang)}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
  <style>
    body {
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      background: radial-gradient(circle at 10% 20%, rgb(17, 17, 17) 0%, rgb(10, 10, 10) 90.1%);
      margin: 0;
      font-family: 'Inter', sans-serif;
    }

    .register-container {
      width: 100%;
      max-width: 440px;
      padding: 40px;
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 16px;
      backdrop-filter: blur(10px);
      box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.5);
      text-align: center;
      animation: fadeIn 0.6s ease-out;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .logo-container {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 10px;
      margin-bottom: 24px;
    }

    .logo-text {
      font-size: 1.5rem;
      font-weight: 800;
      letter-spacing: -0.5px;
      background: linear-gradient(135deg, #8B5CF6, #06B6D4);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    h2 {
      color: #f3f4f6;
      font-size: 1.25rem;
      margin-bottom: 8px;
      font-weight: 600;
    }

    p.subtitle {
      color: #9ca3af;
      font-size: 0.875rem;
      margin-bottom: 24px;
    }

    .info-banner {
      margin-bottom: 24px;
      padding: 12px;
      background: rgba(139, 92, 246, 0.1);
      border: 1px solid rgba(139, 92, 246, 0.25);
      border-radius: 8px;
      color: #c084fc;
      font-size: 0.82rem;
      text-align: left;
      line-height: 1.4;
    }

    .form-group {
      text-align: left;
      margin-bottom: 20px;
    }

    label {
      display: block;
      color: #9ca3af;
      font-size: 0.75rem;
      font-weight: 600;
      margin-bottom: 8px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .input-field {
      width: 100%;
      padding: 12px 16px;
      background: rgba(0, 0, 0, 0.4);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      color: #f3f4f6;
      font-size: 0.9rem;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .input-field:focus {
      border-color: #8b5cf6;
      box-shadow: 0 0 0 2px rgba(139, 92, 246, 0.2);
    }

    .btn-submit {
      width: 100%;
      padding: 14px;
      background: linear-gradient(135deg, #8B5CF6, #6D28D9);
      border: none;
      border-radius: 8px;
      color: white;
      font-weight: 600;
      font-size: 0.95rem;
      cursor: pointer;
      transition: transform 0.15s, opacity 0.2s;
      box-shadow: 0 4px 12px rgba(139, 92, 246, 0.3);
      margin-top: 10px;
    }

    .btn-submit:hover {
      transform: translateY(-1px);
      opacity: 0.95;
    }

    .btn-submit:active {
      transform: translateY(0);
    }

    .error-box {
      margin-bottom: 20px;
      padding: 12px;
      background: rgba(239, 68, 68, 0.1);
      border: 1px solid rgba(239, 68, 68, 0.2);
      border-radius: 8px;
      color: #fca5a5;
      font-size: 0.85rem;
      display: none;
      text-align: left;
    }

    .success-box {
      margin-bottom: 20px;
      padding: 12px;
      background: rgba(16, 185, 129, 0.1);
      border: 1px solid rgba(16, 185, 129, 0.2);
      border-radius: 8px;
      color: #a7f3d0;
      font-size: 0.85rem;
      display: none;
      text-align: left;
    }

    .link-container {
      margin-top: 24px;
      font-size: 0.85rem;
    }

    .link-container a {
      color: #a78bfa;
      text-decoration: none;
      font-weight: 500;
      transition: color 0.2s;
    }

    .link-container a:hover {
      color: #c084fc;
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div class="register-container">
    <div class="logo-container">
      <svg width="32" height="32" viewBox="0 0 28 28" fill="none">
        <circle cx="14" cy="14" r="12" stroke="url(#logo-grad)" stroke-width="2.5" fill="none"/>
        <circle cx="8" cy="11" r="2.5" fill="#8B5CF6"/>
        <circle cx="18" cy="9" r="2.5" fill="#06B6D4"/>
        <circle cx="15" cy="19" r="2.5" fill="#F59E0B"/>
        <line x1="8" y1="11" x2="18" y2="9" stroke="#8B5CF680" stroke-width="1.5"/>
        <line x1="18" y1="9" x2="15" y2="19" stroke="#06B6D480" stroke-width="1.5"/>
        <line x1="8" y1="11" x2="15" y2="19" stroke="#F59E0B80" stroke-width="1.5"/>
        <defs><linearGradient id="logo-grad" x1="0" y1="0" x2="28" y2="28"><stop stop-color="#8B5CF6"/><stop offset="1" stop-color="#06B6D4"/></linearGradient></defs>
      </svg>
      <span class="logo-text">Knowledge Graph</span>
    </div>

    <h2>{t('register_title', currentLang)}</h2>
    <p class="subtitle">{t('register_subtitle', currentLang)}</p>

    <div class="info-banner">
      {adminNotice}
    </div>

    <div id="error-box" class="error-box"></div>
    <div id="success-box" class="success-box"></div>

    <form id="register-form">
      <div class="form-group">
        <label for="name">{t('name', currentLang)}</label>
        <input type="text" id="name" class="input-field" required placeholder="Juan Pérez" autocomplete="name">
      </div>
      <div class="form-group">
        <label for="email">{t('email', currentLang)}</label>
        <input type="email" id="email" class="input-field" required placeholder="tu@email.com" autocomplete="email">
      </div>
      <div class="form-group">
        <label for="password">{t('password', currentLang)}</label>
        <input type="password" id="password" class="input-field" required placeholder="••••••••" autocomplete="new-password">
      </div>

      <button type="submit" id="btn-submit" class="btn-submit">
        {t('register_button', currentLang)}
      </button>
    </form>

    <div class="link-container">
      <a href="/login">{t('already_have_account', currentLang)}</a>
    </div>
  </div>

  <script>
    const form = document.getElementById('register-form') as HTMLFormElement;
    const errorBox = document.getElementById('error-box') as HTMLDivElement;
    const successBox = document.getElementById('success-box') as HTMLDivElement;
    const btnSubmit = document.getElementById('btn-submit') as HTMLButtonElement;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorBox.style.display = 'none';
      successBox.style.display = 'none';
      btnSubmit.disabled = true;
      btnSubmit.textContent = '...';

      const name = (document.getElementById('name') as HTMLInputElement).value;
      const email = (document.getElementById('email') as HTMLInputElement).value;
      const password = (document.getElementById('password') as HTMLInputElement).value;

      try {
        const res = await fetch('/api/auth/register', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, password })
        });
        const data = await res.json();

        if (res.ok && data.success) {
          successBox.textContent = 'Cuenta creada. Redirigiendo al inicio de sesión...';
          successBox.style.display = 'block';
          form.reset();
          setTimeout(() => {
            window.location.href = '/login';
          }, 2000);
        } else {
          errorBox.textContent = data.error || 'Error al registrar la cuenta';
          errorBox.style.display = 'block';
          btnSubmit.disabled = false;
          btnSubmit.textContent = 'Registrar cuenta';
        }
      } catch (err) {
        errorBox.textContent = 'Error de conexión con el servidor';
        errorBox.style.display = 'block';
        btnSubmit.disabled = false;
        btnSubmit.textContent = 'Registrar cuenta';
      }
    });
  </script>
</body>
</html>
