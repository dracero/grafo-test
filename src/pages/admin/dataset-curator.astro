---
import { t } from '../../lib/i18n';
import { getUserByEmail } from '../../lib/mongodb';

const currentLang = Astro.locals.lang || 'es';
const currentUser = Astro.locals.user;

// 1. Authorize: Check if user is logged in and is an admin
if (!currentUser) {
  return Astro.redirect('/login');
}

const dbUser = await getUserByEmail(currentUser.email);
if (!dbUser || dbUser.role !== 'admin') {
  return Astro.redirect('/');
}

// List of agents that can be curated/optimized
const agentsList = [
  { id: 'ComplianceValidatorAgent', name: 'ComplianceValidatorAgent (Validator)' },
  { id: 'ProgramFixerAgent', name: 'ProgramFixerAgent (Fixer)' },
  { id: 'NormativeOntologyAgent', name: 'NormativeOntologyAgent' },
  { id: 'ProgramOntologyAgent', name: 'ProgramOntologyAgent' },
  { id: 'StructureAnalyzerAgent', name: 'StructureAnalyzerAgent' },
  { id: 'ComplianceGapsAgent', name: 'ComplianceGapsAgent' },
  { id: 'OntologyAnalyzerAgent', name: 'OntologyAnalyzerAgent (Rúbricas)' },
  { id: 'SchemaOntologyAdjusterAgent', name: 'SchemaOntologyAdjusterAgent (Rúbricas)' },
  { id: 'RubricSynthesizerAgent', name: 'RubricSynthesizerAgent (Rúbricas)' },
];
---

<!DOCTYPE html>
<html lang={currentLang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Curación de Dataset (Langsmith) — Knowledge Graph</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
  <style>
    body {
      background: radial-gradient(circle at 50% 0%, #151829 0%, #0b0c13 100%);
      font-family: 'Inter', sans-serif;
      color: #e5e7eb;
      margin: 0;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .curator-header {
      background: rgba(17, 24, 39, 0.65);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .header-title-sec {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .header-logo-icon {
      color: #a855f7;
    }

    .curator-header h1 {
      margin: 0;
      font-size: 1.25rem;
      font-weight: 700;
      letter-spacing: -0.025em;
      background: linear-gradient(135deg, #a855f7, #06b6d4);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .btn-back-dashboard {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 16px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 8px;
      color: #d1d5db;
      font-size: 0.85rem;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.2s;
    }

    .btn-back-dashboard:hover {
      background: rgba(255, 255, 255, 0.1);
      color: #fff;
      border-color: rgba(255, 255, 255, 0.15);
      transform: translateX(-2px);
    }

    .curator-main {
      flex: 1;
      padding: 2rem;
      max-width: 1440px;
      margin: 0 auto;
      width: 100%;
      box-sizing: border-box;
      display: grid;
      grid-template-columns: 320px 1fr;
      gap: 2rem;
      overflow-y: auto;
      height: calc(100vh - 80px); /* Subtract header height */
    }

    /* Left panel controls */
    .sidebar-panel {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .card-dark {
      background: rgba(30, 41, 59, 0.25);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 12px;
      padding: 1.25rem;
      backdrop-filter: blur(16px);
      box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    }

    .sidebar-section-title {
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #9ca3af;
      font-weight: 700;
      margin-top: 0;
      margin-bottom: 1rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      padding-bottom: 0.5rem;
    }

    .select-dropdown {
      width: 100%;
      background: rgba(0, 0, 0, 0.3);
      color: #f3f4f6;
      border: 1px solid rgba(255, 255, 255, 0.1);
      padding: 10px;
      border-radius: 8px;
      font-size: 0.875rem;
      outline: none;
      cursor: pointer;
      margin-bottom: 1rem;
      transition: all 0.2s;
    }

    .select-dropdown:focus {
      border-color: #a855f7;
      box-shadow: 0 0 0 2px rgba(168, 85, 247, 0.2);
    }

    .btn-primary-purple {
      width: 100%;
      background: linear-gradient(135deg, #a855f7 0%, #7c3aed 100%);
      color: white;
      border: none;
      padding: 10px 16px;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.875rem;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      transition: all 0.2s;
      box-shadow: 0 4px 12px rgba(168, 85, 247, 0.3);
    }

    .btn-primary-purple:hover {
      opacity: 0.95;
      transform: translateY(-1px);
      box-shadow: 0 6px 16px rgba(168, 85, 247, 0.4);
    }

    /* Runs list */
    .runs-list {
      max-height: 400px;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .run-item-card {
      background: rgba(0, 0, 0, 0.2);
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 8px;
      padding: 10px 12px;
      cursor: pointer;
      transition: all 0.2s;
      position: relative;
    }

    .run-item-card:hover {
      background: rgba(255, 255, 255, 0.03);
      border-color: rgba(255, 255, 255, 0.1);
    }

    .run-item-card.selected {
      background: rgba(168, 85, 247, 0.08);
      border-color: rgba(168, 85, 247, 0.4);
      box-shadow: inset 0 0 8px rgba(168, 85, 247, 0.1);
    }

    .run-item-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 6px;
    }

    .run-id-lbl {
      font-size: 0.75rem;
      font-family: monospace;
      color: #9ca3af;
    }

    .run-status-badge {
      font-size: 0.65rem;
      font-weight: 700;
      padding: 2px 6px;
      border-radius: 4px;
      text-transform: uppercase;
    }

    .run-status-badge.success {
      background: rgba(16, 185, 129, 0.15);
      color: #34d399;
      border: 1px solid rgba(16, 185, 129, 0.3);
    }

    .run-status-badge.failed {
      background: rgba(239, 68, 68, 0.15);
      color: #f87171;
      border: 1px solid rgba(239, 68, 68, 0.3);
    }

    .run-time-lbl {
      font-size: 0.7rem;
      color: #6b7280;
    }

    /* Main split curation panel */
    .curator-workspace {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .curator-workspace.empty-workspace {
      justify-content: center;
      align-items: center;
      height: 100%;
      border: 2px dashed rgba(255, 255, 255, 0.06);
      border-radius: 12px;
      color: #9ca3af;
      text-align: center;
      padding: 4rem;
    }

    .workspace-empty-title {
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 6px;
      color: #d1d5db;
    }

    .workspace-empty-subtitle {
      font-size: 0.85rem;
      color: #6b7280;
    }

    .split-container {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      flex: 1;
    }

    .split-col {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .pane-title {
      font-size: 0.85rem;
      font-weight: 600;
      color: #9ca3af;
      margin: 0;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .pane-content-box {
      flex: 1;
      background: rgba(0, 0, 0, 0.25);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 10px;
      padding: 1rem;
      font-family: monospace;
      font-size: 0.8rem;
      overflow: auto;
      height: 380px;
      box-sizing: border-box;
      white-space: pre-wrap;
      color: #c9d1d9;
    }

    .editor-textarea {
      width: 100%;
      height: 380px;
      background: rgba(0, 0, 0, 0.35);
      border: 1px solid rgba(168, 85, 247, 0.3);
      border-radius: 10px;
      padding: 1rem;
      font-family: monospace;
      font-size: 0.8rem;
      color: #c084fc;
      outline: none;
      resize: vertical;
      box-sizing: border-box;
      line-height: 1.5;
    }

    .editor-textarea:focus {
      border-color: #a855f7;
      box-shadow: 0 0 0 2px rgba(168, 85, 247, 0.2);
    }

    .workspace-footer {
      display: flex;
      justify-content: flex-end;
      gap: 12px;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
      padding-top: 1.25rem;
    }

    .btn-secondary {
      background: rgba(255, 255, 255, 0.05);
      color: #d1d5db;
      border: 1px solid rgba(255, 255, 255, 0.08);
      padding: 10px 20px;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.875rem;
      cursor: pointer;
      transition: all 0.2s;
    }

    .btn-secondary:hover {
      background: rgba(255, 255, 255, 0.08);
      color: #fff;
    }

    /* Current Dataset Examples List */
    .dataset-overview-card {
      margin-top: 2rem;
      margin-bottom: 2rem; /* Add bottom margin to ensure visibility */
    }

    .dataset-table-sec {
      overflow-x: auto;
      margin-top: 1rem;
    }

    .dataset-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.85rem;
      text-align: left;
    }

    .dataset-table th {
      padding: 8px 12px;
      border-bottom: 2px solid rgba(255, 255, 255, 0.08);
      color: #9ca3af;
      font-weight: 600;
    }

    .dataset-table td {
      padding: 12px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      vertical-align: middle;
    }

    .btn-delete-row {
      background: rgba(239, 68, 68, 0.1);
      color: #f87171;
      border: 1px solid rgba(239, 68, 68, 0.2);
      border-radius: 6px;
      padding: 4px 8px;
      cursor: pointer;
      transition: all 0.2s;
      font-size: 0.75rem;
    }

    .btn-delete-row:hover {
      background: rgba(239, 68, 68, 0.25);
      color: #fff;
    }

    .loading-mini-spinner {
      border: 2px solid rgba(255, 255, 255, 0.1);
      border-top: 2px solid #a855f7;
      border-radius: 50%;
      width: 16px;
      height: 16px;
      animation: spin-mini 1s linear infinite;
      display: inline-block;
    }

    @keyframes spin-mini {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    .alert-banner {
      padding: 10px 16px;
      border-radius: 8px;
      font-size: 0.85rem;
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 1.25rem;
      box-sizing: border-box;
    }

    .alert-banner.success {
      background: rgba(16, 185, 129, 0.12);
      color: #34d399;
      border: 1px solid rgba(16, 185, 129, 0.25);
    }

    .alert-banner.error {
      background: rgba(239, 68, 68, 0.12);
      color: #fca5a5;
      border: 1px solid rgba(239, 68, 68, 0.25);
    }
  </style>
</head>
<body>
  <!-- Header -->
  <header class="curator-header">
    <div class="header-title-sec">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="header-logo-icon">
        <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path>
      </svg>
      <h1>Curador de Dataset de Optimización (Langsmith)</h1>
    </div>
    <a href="/" class="btn-back-dashboard">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
      </svg>
      Volver al Explorador
    </a>
  </header>

  <!-- Main Grid -->
  <main class="curator-main">
    
    <!-- Sidebar Panel: Agent Selector & Runs List -->
    <div class="sidebar-panel">
      
      <!-- Selection Card -->
      <div class="card-dark">
        <h2 class="sidebar-section-title">Configuración</h2>
        
        <label for="agent-select" style="font-size: 0.8rem; color: #9ca3af; display: block; margin-bottom: 6px;">Seleccionar Agente</label>
        <select id="agent-select" class="select-dropdown">
          {agentsList.map(a => (
            <option value={a.id}>{a.name}</option>
          ))}
        </select>
        
        <button id="btn-fetch-runs" class="btn-primary-purple">
          <span>Buscar Corridas</span>
        </button>
      </div>

      <!-- Runs List Card -->
      <div class="card-dark" style="flex: 1; display: flex; flex-direction: column;">
        <h2 class="sidebar-section-title">Corridas en Langsmith</h2>
        <div id="runs-list-container" class="runs-list">
          <div style="color: #6b7280; font-size: 0.85rem; text-align: center; padding: 2rem 0;">
            Selecciona un agente y haz clic en "Buscar Corridas" para cargar datos desde Langsmith.
          </div>
        </div>
      </div>

    </div>

    <!-- Main Workspace: Split Curation Pane -->
    <div style="display: flex; flex-direction: column; overflow-y: auto; max-height: calc(100vh - 120px);">
      
      <!-- Notification banner -->
      <div id="notification-banner-area"></div>

      <!-- Curation Workspace Card -->
      <div id="workspace-container" class="card-dark curator-workspace empty-workspace" style="flex: 1; display: flex;">
        <div class="workspace-empty-title">Ninguna corrida seleccionada</div>
        <div class="workspace-empty-subtitle">Elige una corrida de la lista izquierda para editar su salida e incorporarla al Gold Standard.</div>
      </div>

      <!-- Current Gold Standard Examples Overview -->
      <div class="card-dark dataset-overview-card">
        <h2 class="sidebar-section-title">Ejemplos Curados (Gold Standard) para este Agente</h2>
        <div class="dataset-table-sec">
          <table class="dataset-table">
            <thead>
              <tr>
                <th style="width: 25%;">Inputs (Resumen)</th>
                <th>Salida Esperada (Resumen)</th>
                <th style="width: 180px;">Trazabilidad</th>
                <th style="width: 100px; text-align: center;">Acciones</th>
              </tr>
            </thead>
            <tbody id="dataset-table-body">
              <tr>
                <td colspan="4" style="text-align: center; color: #6b7280; padding: 1.5rem;">
                  No hay ejemplos curados en el dataset para el agente seleccionado.
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

    </div>

  </main>

  <!-- Client Script for Interactive Logic -->
  <script>
    let activeAgent = '';
    let selectedRun: any = null;
    let fetchedRuns: any[] = [];

    // Elements
    const agentSelect = document.getElementById('agent-select') as HTMLSelectElement;
    const btnFetchRuns = document.getElementById('btn-fetch-runs') as HTMLButtonElement;
    const runsListContainer = document.getElementById('runs-list-container') as HTMLDivElement;
    const workspaceContainer = document.getElementById('workspace-container') as HTMLDivElement;
    const datasetTableBody = document.getElementById('dataset-table-body') as HTMLTableSectionElement;
    const bannerArea = document.getElementById('notification-banner-area') as HTMLDivElement;

    // Helper: Show Alert banner
    function showAlert(message: string, type: 'success' | 'error') {
      bannerArea.innerHTML = `
        <div class="alert-banner ${type}">
          <span>${type === 'success' ? '✔' : '❌'}</span>
          <span>${message}</span>
        </div>
      `;
      setTimeout(() => {
        bannerArea.innerHTML = '';
      }, 5000);
    }

    // Load active dataset examples
    async function loadDatasetExamples(agentName: string) {
      try {
        const res = await fetch(`/api/admin/dataset?agentName=${agentName}`);
        const data = await res.json();
        
        if (!data.success) {
          datasetTableBody.innerHTML = `<tr><td colspan="4" style="text-align: center; color: #f87171; padding: 1.5rem;">Error al cargar dataset: ${data.error}</td></tr>`;
          return;
        }

        const examples = data.data || [];
        if (examples.length === 0) {
          datasetTableBody.innerHTML = `<tr><td colspan="4" style="text-align: center; color: #6b7280; padding: 1.5rem;">No hay ejemplos curados en el dataset para este agente.</td></tr>`;
          return;
        }

        datasetTableBody.innerHTML = examples.map((ex: any) => {
          // Truncate details for summary columns
          const inputsStr = JSON.stringify(ex.inputs);
          const inputSummary = inputsStr.length > 80 ? inputsStr.substring(0, 80) + '...' : inputsStr;
          const outputSummary = ex.expectedOutput.length > 120 ? ex.expectedOutput.substring(0, 120) + '...' : ex.expectedOutput;
          
          return `
            <tr data-example-id="${ex._id}">
              <td style="font-family: monospace; font-size: 0.75rem; color: #9ca3af; word-break: break-all;">${escapeHtml(inputSummary)}</td>
              <td style="font-family: monospace; font-size: 0.75rem; color: #c084fc; white-space: pre-wrap;">${escapeHtml(outputSummary)}</td>
              <td style="font-size: 0.75rem; color: #6b7280;">
                <div>ID: <span style="font-family: monospace;">${ex._id}</span></div>
                ${ex.sourceRunId ? `<div style="margin-top: 4px;">Run: <a href="https://smith.langchain.com/o/default/projects/p/trazas_gepa/runs/${ex.sourceRunId}" target="_blank" style="color: #a855f7; text-decoration: underline; font-family: monospace;">${ex.sourceRunId.substring(0, 8)}</a></div>` : ''}
              </td>
              <td style="text-align: center;">
                <button class="btn-delete-row" data-example-id="${ex._id}">Eliminar</button>
              </td>
            </tr>
          `;
        }).join('');

        // Attach delete listeners
        const deleteButtons = datasetTableBody.querySelectorAll('.btn-delete-row');
        deleteButtons.forEach(btn => {
          btn.addEventListener('click', async (e) => {
            const btnEl = e.currentTarget as HTMLButtonElement;
            const exampleId = btnEl.dataset.exampleId;
            if (!exampleId) return;

            if (confirm('¿Estás seguro de que deseas eliminar este ejemplo del Gold Standard?')) {
              try {
                const delRes = await fetch(`/api/admin/dataset?id=${exampleId}`, { method: 'DELETE' });
                const delData = await delRes.json();
                if (delData.success) {
                  showAlert('Ejemplo eliminado correctamente del dataset.', 'success');
                  loadDatasetExamples(agentName);
                } else {
                  showAlert(`Error al eliminar: ${delData.error}`, 'error');
                }
              } catch (err: any) {
                showAlert(`Error de conexión: ${err.message}`, 'error');
              }
            }
          });
        });

      } catch (err: any) {
        datasetTableBody.innerHTML = `<tr><td colspan="4" style="text-align: center; color: #f87171; padding: 1.5rem;">Error de red: ${err.message}</td></tr>`;
      }
    }

    // Fetch Runs from Langsmith
    async function fetchLangsmithRuns() {
      const agentName = agentSelect.value;
      activeAgent = agentName;
      selectedRun = null;
      workspaceContainer.innerHTML = `
        <div class="workspace-empty-title">Ninguna corrida seleccionada</div>
        <div class="workspace-empty-subtitle">Elige una corrida de la lista izquierda para editar su salida e incorporarla al Gold Standard.</div>
      `;
      workspaceContainer.className = 'card-dark curator-workspace empty-workspace';

      // Load active dataset list
      loadDatasetExamples(agentName);

      // Fetch runs
      runsListContainer.innerHTML = `
        <div style="text-align: center; padding: 2rem 0;">
          <div class="loading-mini-spinner"></div>
          <div style="margin-top: 8px; color: #9ca3af; font-size: 0.85rem;">Conectando con Langsmith...</div>
        </div>
      `;

      try {
        const res = await fetch(`/api/admin/langsmith/runs?agentName=${agentName}`);
        const data = await res.json();

        if (!data.success) {
          runsListContainer.innerHTML = `<div style="color: #f87171; font-size: 0.85rem; text-align: center; padding: 1rem;">Error: ${data.error}</div>`;
          return;
        }

        fetchedRuns = data.data || [];
        if (fetchedRuns.length === 0) {
          runsListContainer.innerHTML = `<div style="color: #6b7280; font-size: 0.85rem; text-align: center; padding: 2rem 0;">No se encontraron ejecuciones recientes para este agente en Langsmith.</div>`;
          return;
        }

        renderRunsList();
      } catch (err: any) {
        runsListContainer.innerHTML = `<div style="color: #f87171; font-size: 0.85rem; text-align: center; padding: 1rem;">Error de red: ${err.message}</div>`;
      }
    }

    // Render Runs List
    function renderRunsList() {
      runsListContainer.innerHTML = fetchedRuns.map((run: any, idx: number) => {
        const timeStr = new Date(run.createdAt).toLocaleString();
        const runIdShort = run.id.substring(0, 8);
        const statusClass = run.status?.toLowerCase() === 'success' ? 'success' : 'failed';
        
        return `
          <div class="run-item-card" data-run-idx="${idx}" id="run-card-${idx}">
            <div class="run-item-header">
              <span class="run-id-lbl">Run #${runIdShort}</span>
              <span class="run-status-badge ${statusClass}">${run.status}</span>
            </div>
            <div class="run-time-lbl">${timeStr}</div>
          </div>
        `;
      }).join('');

      // Add click listeners to items
      fetchedRuns.forEach((run, idx) => {
        const card = document.getElementById(`run-card-${idx}`);
        card?.addEventListener('click', () => {
          // Deselect previous
          const prevSelected = runsListContainer.querySelector('.run-item-card.selected');
          prevSelected?.classList.remove('selected');
          
          // Select current
          card.classList.add('selected');
          selectedRun = run;
          loadRunIntoWorkspace(run);
        });
      });
    }

    // Load selected run details into curation panel
    function loadRunIntoWorkspace(run: any) {
      // Re-enable workspace structure
      workspaceContainer.className = 'card-dark curator-workspace';
      
      // Clean inputs object to display only relevant state parameters for the agent
      const cleanInputs = getFilteredAgentInputs(activeAgent, run.inputs);

      // Clean LLM output to prevent markdown formatting issues
      let cleanOutput = run.output;
      try {
        // Try parsing/formatting if it is JSON
        const parsed = JSON.parse(run.output);
        cleanOutput = JSON.stringify(parsed, null, 2);
      } catch {
        // Leave as is if not JSON
      }

      workspaceContainer.innerHTML = `
        <div style="border-bottom: 1px solid rgba(255, 255, 255, 0.06); padding-bottom: 10px; display: flex; justify-content: space-between; align-items: center;">
          <div>
            <h2 style="font-size: 1.05rem; font-weight: 600; color: #f3f4f6; margin: 0;">Corrida ID: ${run.id}</h2>
            <span style="font-size: 0.75rem; color: #9ca3af;">Trazado e importado desde Langsmith</span>
          </div>
          <a href="https://smith.langchain.com/o/default/projects/p/trazas_gepa/runs/${run.id}" target="_blank" style="font-size: 0.75rem; color: #a855f7; text-decoration: underline;">Ver traza completa en Langsmith ↗</a>
        </div>

        <div class="split-container">
          <!-- Left Col: inputs -->
          <div class="split-col">
            <h3 class="pane-title">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
              Inputs del Agente (Inputs de la Firma)
            </h3>
            <div class="pane-content-box" id="inputs-content-box" style="white-space: normal; display: flex; flex-direction: column; gap: 16px;"></div>
          </div>

          <!-- Right Col: expected outputs editor -->
          <div class="split-col">
            <h3 class="pane-title" style="color: #c084fc;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
              Salida Esperada (Curation Editor)
            </h3>
            <textarea class="editor-textarea" id="output-editor-textarea">${escapeHtml(cleanOutput)}</textarea>
          </div>
        </div>

        <div class="workspace-footer">
          <button class="btn-secondary" id="btn-reset-output">Deshacer Cambios</button>
          <button class="btn-primary-purple" id="btn-save-dataset" style="width: auto;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
            Guardar en Gold Standard
          </button>
        </div>
      `;

      // Render human readable plain text inputs with whitespace and newlines preserved
      const inputsBox = document.getElementById('inputs-content-box') as HTMLDivElement;
      if (inputsBox) {
        inputsBox.innerHTML = Object.entries(cleanInputs)
          .map(([key, value]) => {
            const formattedVal = formatValueForDisplay(value);
            return `
              <div style="border-bottom: 1px solid rgba(255, 255, 255, 0.05); padding-bottom: 12px; margin-bottom: 4px;">
                <div style="color: #c084fc; font-weight: 700; font-size: 0.75rem; text-transform: uppercase; margin-bottom: 6px; letter-spacing: 0.05em; font-family: sans-serif;">${escapeHtml(key)}</div>
                <div style="max-height: 220px; overflow-y: auto; white-space: pre-wrap; color: #e5e7eb; font-family: monospace; font-size: 0.8rem; line-height: 1.5; word-break: break-word; background: rgba(0, 0, 0, 0.15); padding: 8px; border-radius: 6px; border: 1px solid rgba(255, 255, 255, 0.03);">${formattedVal || '<span style="color: #6b7280; font-style: italic;">(vacío)</span>'}</div>
              </div>
            `;
          })
          .join('');
      }

      // Event listener for Reset
      const btnReset = document.getElementById('btn-reset-output') as HTMLButtonElement;
      btnReset.addEventListener('click', () => {
        const editorTextarea = document.getElementById('output-editor-textarea') as HTMLTextAreaElement;
        editorTextarea.value = cleanOutput;
      });

      // Event listener for Save to Gold Standard
      const btnSave = document.getElementById('btn-save-dataset') as HTMLButtonElement;
      btnSave.addEventListener('click', async () => {
        const editorTextarea = document.getElementById('output-editor-textarea') as HTMLTextAreaElement;
        const expectedVal = editorTextarea.value.trim();

        if (!expectedVal) {
          alert('La salida esperada no puede estar vacía');
          return;
        }

        btnSave.disabled = true;
        btnSave.innerHTML = '<span class="loading-mini-spinner"></span> Guardando...';

        try {
          const saveRes = await fetch('/api/admin/dataset', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              agentName: activeAgent,
              inputs: cleanInputs,
              expectedOutput: expectedVal,
              sourceRunId: run.id
            })
          });

          const saveData = await saveRes.json();
          if (saveData.success) {
            showAlert('Ejemplo guardado con éxito en el Gold Standard!', 'success');
            // Refresh dataset list
            loadDatasetExamples(activeAgent);
          } else {
            showAlert(`Error al guardar: ${saveData.error}`, 'error');
          }
        } catch (err: any) {
          showAlert(`Error de conexión: ${err.message}`, 'error');
        } finally {
          btnSave.disabled = false;
          btnSave.innerHTML = `
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
            Guardar en Gold Standard
          `;
        }
      });
    }

    // Filters the trace session/spans inputs based on the specific agent's signature
    function getFilteredAgentInputs(agent: string, rawInputs: any): Record<string, any> {
      // If inputs are already structured under keys, try to extract them.
      // In our ADK monkey patch, we stringify the state context which contains key-value states.
      let state = rawInputs;
      if (rawInputs && typeof rawInputs === 'object' && rawInputs.inputs) {
        try {
          state = JSON.parse(rawInputs.inputs);
        } catch {
          state = rawInputs.inputs;
        }
      }

      const cleanObj: Record<string, any> = {};

      switch (agent) {
        case 'NormativeOntologyAgent':
          cleanObj.normativeName = state?.normativeName || state?.['app:normative_doc'] || '';
          cleanObj.programName = state?.programName || state?.['app:program_doc'] || '';
          cleanObj.ontology = state?.ontology || '';
          cleanObj.targetLangName = state?.targetLangName || '';
          break;
        case 'ProgramOntologyAgent':
          cleanObj.normativeName = state?.normativeName || state?.['app:normative_doc'] || '';
          cleanObj.programName = state?.programName || state?.['app:program_doc'] || '';
          cleanObj.ontology = state?.ontology || '';
          cleanObj.targetLangName = state?.targetLangName || '';
          break;
        case 'StructureAnalyzerAgent':
          cleanObj.programName = state?.programName || state?.['app:program_doc'] || '';
          cleanObj.originalText = state?.originalText || '';
          break;
        case 'ComplianceGapsAgent':
          cleanObj.normativeName = state?.normativeName || state?.['app:normative_doc'] || '';
          cleanObj.programName = state?.programName || state?.['app:program_doc'] || '';
          cleanObj.gaps = state?.gaps || '';
          cleanObj.targetLangName = state?.targetLangName || '';
          break;
        case 'ComplianceValidatorAgent':
          cleanObj.complianceAnalysis = state?.complianceAnalysis || state?.['app:compliance_analysis'] || '';
          cleanObj.originalText = state?.originalText || '';
          cleanObj.targetLangName = state?.targetLangName || '';
          break;
        case 'ProgramFixerAgent':
          cleanObj.normativeAnalysis = state?.normativeAnalysis || state?.['app:normative_analysis'] || '';
          cleanObj.validatedComplianceAnalysis = state?.validatedComplianceAnalysis || state?.['app:validated_compliance_analysis'] || '';
          cleanObj.originalStructure = state?.originalStructure || state?.['app:original_structure'] || '';
          cleanObj.originalText = state?.originalText || '';
          cleanObj.validatedGapsCount = state?.validatedGapsCount !== undefined ? state.validatedGapsCount : 0;
          cleanObj.targetLangName = state?.targetLangName || '';
          break;
        case 'OntologyAnalyzerAgent':
          cleanObj.targetLangName = state?.targetLangName || '';
          cleanObj.ontology = state?.ontology || '';
          break;
        case 'SchemaOntologyAdjusterAgent':
          cleanObj.targetLangName = state?.targetLangName || '';
          cleanObj.ontologyAnalysis = state?.ontologyAnalysis || state?.['app:ontology_analysis'] || '';
          cleanObj.ontology = state?.ontology || '';
          cleanObj.evaluationSchema = state?.evaluationSchema || '';
          break;
        case 'RubricSynthesizerAgent':
          cleanObj.targetLangName = state?.targetLangName || '';
          cleanObj.ontologyAnalysis = state?.ontologyAnalysis || state?.['app:ontology_analysis'] || '';
          cleanObj.adjustedOntology = state?.adjustedOntology || state?.['app:adjusted_ontology'] || '';
          cleanObj.evaluationSchema = state?.evaluationSchema || '';
          break;
        default:
          return state;
      }

      return cleanObj;
    }

    // Format a value for display in the inputs panel as human-readable text
    function formatValueForDisplay(value: any): string {
      if (value === null || value === undefined) return '';

      // Primitive: render as string
      if (typeof value !== 'object') {
        return escapeHtml(String(value));
      }

      // Object with a single 'text' property (common from Langsmith state): unwrap and show as plain text
      if (!Array.isArray(value) && typeof value.text === 'string') {
        return escapeHtml(value.text);
      }

      // Array of gap/ontology objects: format each item as a readable line
      if (Array.isArray(value)) {
        if (value.length === 0) return '<span style="color: #6b7280; font-style: italic;">(lista vacía)</span>';

        return value.map((item: any, idx: number) => {
          if (typeof item === 'object' && item !== null) {
            // Format gap-like objects with known fields
            const parts: string[] = [];
            if (item.id) parts.push(`[${escapeHtml(item.id)}]`);
            if (item.requirement) parts.push(escapeHtml(item.requirement));
            if (item.status) parts.push(`(${escapeHtml(item.status)})`);
            if (item.category) parts.push(`Categoría: ${escapeHtml(item.category)}`);
            if (item.description) parts.push(`\n  Descripción: ${escapeHtml(item.description)}`);
            if (item.evidence) parts.push(`\n  Evidencia: ${escapeHtml(item.evidence)}`);
            if (item.suggestion) parts.push(`\n  Sugerencia: ${escapeHtml(item.suggestion)}`);

            if (parts.length > 0) {
              return `${idx + 1}. ${parts.join(' ')}`;
            }
            // Generic object in array
            return `${idx + 1}. ${escapeHtml(JSON.stringify(item, null, 2))}`;
          }
          return `${idx + 1}. ${escapeHtml(String(item))}`;
        }).join('\n\n');
      }

      // Generic object: stringify as JSON
      return escapeHtml(JSON.stringify(value, null, 2));
    }

    // HTML escape helper
    function escapeHtml(str: string): string {
      return str
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    // Attach listener
    btnFetchRuns.addEventListener('click', fetchLangsmithRuns);

    // Initial load
    const initialAgent = agentSelect.value;
    loadDatasetExamples(initialAgent);
  </script>
</body>
</html>
