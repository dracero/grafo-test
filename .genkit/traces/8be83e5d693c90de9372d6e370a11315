  \\\"keywords\\\": [\\\"modelado de datos\\\", \\\"diseño de esquemas\\\", \\\"optimización de datos\\\", \\\"Ingeniería de Datos\\\"]\\n    },\\n    {\\n      \\\"id\\\": \\\"PROG-CONT-C_INGENIERIADATOS_003\\\",\\n      \\\"category\\\": \\\"Contenido\\\",\\n      \\\"requirement\\\": \\\"Almacenamiento y recuperación de datos (Ingeniería de Datos)\\\",\\n      \\\"description\\\": \\\"Almacenamiento y recuperación de datos. Selección de tecnologías de almacenamiento de datos adecuadas, bases de datos, sistemas de archivos y data, así como el diseño de mecanismos de recuperación que permitan la consulta y recuperación eficientes de datos.\\\",\\n      \\\"keywords\\\": [\\\"almacenamiento de datos\\\", \\\"recuperación de datos\\\", \\\"tecnologías de almacenamiento\\\", \\\"bases de datos\\\", \\\"sistemas de archivos\\\", \\\"consulta eficiente\\\", \\\"Ingeniería de Datos\\\"]\\n    },\\n    {\\n      \\\"id\\\": \\\"PROG-CONT-C_INGENIERIADATOS_004\\\",\\n      \\\"category\\\": \\\"Contenido\\\",\\n      \\\"requirement\\\": \\\"Procesamiento e integración de datos. Calidad (Ingeniería de Datos)\\\",\\n      \\\"description\\\": \\\"Procesamiento de datos. Diseñar pipelines que puedan transformar los datos en bruto en un formato utilizable. Integración de datos. Calidad de datos, validación de datos, perfilado de datos y monitoreo de datos.\\\",\\n      \\\"keywords\\\": [\\\"procesamiento de datos\\\", \\\"pipelines de datos\\\", \\\"transformación de datos\\\", \\\"integración de datos\\\", \\\"calidad de datos\\\", \\\"validación de datos\\\", \\\"perfilado de datos\\\", \\\"monitoreo de datos\\\", \\\"Ingeniería de Datos\\\"]\\n    },\\n    {\\n      \\\"id\\\": \\\"PROG-CONT-C_OPTICONVEXA_002\\\",\\n      \\\"category\\\": \\\"Contenido\\\",\\n      \\\"requirement\\\": \\\"Fundamentos matemáticos de la optimización (Optimización Convexa)\\\",\\n      \\\"description\\\": \\\"Fundamentos matemáticos de la optimización. Funciones objetivo. Análisis de conv